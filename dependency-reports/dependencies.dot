digraph Dependencies {
    rankdir=LR;
    node [shape=box, style=rounded, fontname="Arial"];
    edge [fontname="Arial"];
    
    "terraform-plan" [fillcolor=orange, style="filled,rounded"];
    "terraform-apply" [fillcolor=red, style="filled,rounded"];
    "deployment" [fillcolor=red, style="filled,rounded"];
".github/workflows/deployment.yml" -> "scripts/deploy-full-stack.sh" [label="calls"];
".github/workflows/deployment.yml" -> ".github/workflows/terraform-apply.yml" [label="requires"];
".github/workflows/terraform-apply.yml" -> "scripts/terraform-apply.sh" [label="calls"];
".github/workflows/terraform-apply.yml" -> "scripts/validate-state.sh" [label="requires"];
".github/workflows/terraform-plan.yml" -> "scripts/terraform-validate.sh" [label="calls"];
".github/workflows/deployment.yml" -> "AWS_OIDC_ROLE_ARN" [label="requires_secret"];
".github/workflows/terraform-plan.yml" -> "AWS_OIDC_ROLE_ARN" [label="requires_secret"];
".github/workflows/terraform-apply.yml" -> "AWS_OIDC_ROLE_ARN" [label="requires_secret"];
"scripts/deploy-full-stack.sh" -> "scripts/pre-deploy-check.sh" [label="calls"];
"scripts/deploy-full-stack.sh" -> "scripts/post-deploy-validation.sh" [label="calls"];
}
