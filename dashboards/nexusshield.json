{
  "title": "NexusShield - Overview",
  "panels": [
    {
      "type": "graph",
      "title": "HTTP Request Rate (5m)",
      "targets": [ { "expr": "sum(rate(nexusshield_http_requests_total[5m]))" } ]
    },
    {
      "type": "graph",
      "title": "Job Events (count)",
      "targets": [ { "expr": "sum(nexusshield_jobs_total) by (event)" } ]
    },
    {
      "type": "graph",
      "title": "Job Duration (95th percentile)",
      "targets": [ { "expr": "histogram_quantile(0.95, sum(rate(nexusshield_job_duration_seconds_bucket[5m])) by (le))" } ]
    },
    {
      "type": "stat",
      "title": "Audit Entries",
      "targets": [ { "expr": "sum(increase(nexusshield_jobs_total[1h]))" } ]
    }
  ],
  "templating": { "list": [] }
}
