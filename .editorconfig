root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
max_line_length = 120

[*.md]
trim_trailing_whitespace = false
# EditorConfig helps maintain consistent coding styles across different editors and IDEs
# https://editorconfig.org/

root = true

# Universal settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# YAML files (GitHub Actions, configs)
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# JSON files
[*.json]
indent_style = space
indent_size = 2

# Markdown files
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false  # Preserve double-space line breaks

# JavaScript/TypeScript
[*.{js,jsx,ts,tsx,cjs,mjs}]
indent_style = space
indent_size = 2
quote_type = single

# Python
[*.py]
indent_style = space
indent_size = 4
max_line_length = 100

# Bash/Shell scripts
[*.{sh,bash}]
indent_style = space
indent_size = 2

# Terraform/HCL
[*.{tf,tfvars}]
indent_style = space
indent_size = 2

# Makefile (must use tabs)
[Makefile]
indent_style = tab

# Docker files
[Dockerfile*]
indent_style = space
indent_size = 2

# Properties files
[*.properties]
indent_style = space
indent_size = 2

# CSV files
[*.csv]
trim_trailing_whitespace = false  # Preserve formatting
