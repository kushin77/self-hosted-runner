# NexusShield Portal - Production Environment Configuration
# ⚠️  WARNING: Replace all example values with real production credentials
# Store this file securely - it contains sensitive credentials

# ===== DATABASE CONFIG =====
DB_PASSWORD=your_secure_postgres_password_here
DATABASE_URL=postgresql://portal:${DB_PASSWORD}@postgres:5432/nexusshield

# ===== CACHE CONFIG =====
REDIS_PASSWORD=your_secure_redis_password_here
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# ===== GCP CONFIGURATION =====
GCP_PROJECT_ID=nexusshield-prod
GCP_KMS_KEY=projects/nexusshield-prod/locations/us-central1/keyRings/portal-kr/cryptoKeys/portal-key
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcp_key.json

# ===== API CONFIGURATION =====
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
API_BASE_URL=http://backend:3000

# ===== FRONTEND CONFIG =====
REACT_APP_API_URL=http://localhost:3000
FRONTEND_PORT=3001

# ===== SECURITY =====
JWT_SECRET=your_jwt_secret_key_here_min_32_chars
CORS_ORIGIN=http://localhost:3001,https://yourdomain.com

# ===== FEATURE FLAGS =====
ENABLE_GSM_VAULT=true
ENABLE_KMS_ENCRYPTION=true
ENABLE_AUDIT_LOGGING=true
ENABLE_METRICS=true

# ===== OBSERVABILITY =====
PROMETHEUS_PORT=9090
METRICS_ENABLED=true
