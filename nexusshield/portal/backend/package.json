{
  "name": "nexusshield-portal-backend",
  "version": "1.0.0",
  "description": "NexusShield Enterprise Control Plane - Backend API (Node.js + Express + GraphQL)",
  "main": "src/server.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx src/db/migrations/run.ts",
    "seed": "tsx src/db/seeds/run.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "apollo-server-express": "^4.9.1",
    "graphql": "^16.6.0",
    "graphql-tools": "^9.0.0",
    "passport": "^0.7.0",
    "passport-oauth2": "^1.7.0",
    "passport-jwt": "^4.1.1",
    "pg": "^8.10.0",
    "redis": "^4.6.5",
    "winston": "^3.8.2",
    "pino": "^8.14.1",
    "dotenv": "^16.3.1",
    "joi": "^17.9.2",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "compression": "^1.7.4",
    "uuid": "^9.0.0",
    "@google-cloud/secret-manager": "^4.2.0",
    "@aws-sdk/client-kms": "^3.350.0",
    "axios": "^1.4.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.1",
    "@types/jwt-decode": "^3.1.0",
    "typescript": "^5.1.3",
    "tsx": "^3.13.0",
    "jest": "^29.5.0",
    "@types/jest": "^29.5.2",
    "ts-jest": "^29.1.0",
    "eslint": "^8.43.0",
    "@typescript-eslint/eslint-plugin": "^5.59.11",
    "@typescript-eslint/parser": "^5.59.11",
    "prettier": "^2.8.8"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "nexusshield",
    "zero-trust",
    "credential-management",
    "multi-cloud",
    "secrets",
    "vault",
    "gcp",
    "aws",
    "azure"
  ],
  "author": "NexusShield Team",
  "license": "Proprietary"
}
