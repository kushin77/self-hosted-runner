{
  "name": "self-hosted-runner-dev",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker": {}
  },
  "extensions": [
    "ms-azuretools.vscode-docker",
    "esbenp.prettier-vscode",
    "ms-python.python",
    "golang.go"
  ],
  "postCreateCommand": "bash .devcontainer/post-create.sh || true"
}
{
  "name": "Self-Hosted Runner Dev Environment",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-22.04",
  "features": {
    "ghcr.io/devcontainers/features/node:18": {},
    "ghcr.io/devcontainers/features/python:3.11": {},
    "ghcr.io/devcontainers/features/docker-in-docker:latest": {},
    "ghcr.io/devcontainers/features/git:latest": {},
    "ghcr.io/devcontainers/features/terraform:latest": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "charliermarsh.ruff",
        "esbenp.prettier-vscode",
        "golang.go",
        "hashicorp.terraform",
        "ms-vscode-remote.remote-containers",
        "redhat.vscode-yaml",
        "GitHub.copilot",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "dbaeumer.vscode-eslint",
        "timonwong.shellcheck",
        "ms-vscode.makefile-tools"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python3",
        "python.linting.enabled": true,
        "python.linting.pylintEnabled": true,
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.formatOnSave": true
        },
        "[shell]": {
          "editor.defaultFormatter": "mads-hartmann.bash-ide-vscode",
          "editor.formatOnSave": true
        }
      }
    }
  },
  "onCreateCommand": "",
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "forwardPorts": [
    3000,
    5000,
    8000,
    8080,
    8081,
    6379,
    5432,
    9090,
    9091,
    3333
  ],
  "portsAttributes": {
    "3000": {
      "label": "Portal UI",
      "onAutoForward": "notify"
    },
    "8000": {
      "label": "Provisioner Worker",
      "onAutoForward": "notify"
    },
    "8080": {
      "label": "VaultShim",
      "onAutoForward": "notify"
    },
    "6379": {
      "label": "Redis",
      "onAutoForward": "silent"
    },
    "5432": {
      "label": "PostgreSQL",
      "onAutoForward": "silent"
    },
    "9090": {
      "label": "Prometheus",
      "onAutoForward": "notify"
    },
    "9091": {
      "label": "Prometheus Push Gateway",
      "onAutoForward": "silent"
    }
  },
  "remoteEnv": {
    "DOCKER_BUILDKIT": "1",
    "COMPOSE_DOCKER_CLI_BUILD": "1",
    "PATH": "${containerEnv:PATH}:/usr/local/go/bin:/home/vscode/.local/bin"
  },
  "remoteUser": "vscode",
  "mounts": [
    "source=${localEnv:HOME}/.ssh,target=/home/vscode/.ssh,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.gitconfig,target=/home/vscode/.gitconfig,type=bind"
  ]
    },
    "5000": {
      "label": "Flask API",
      "onAutoForward": "notify"
    },
    "8080": {
      "label": "Web UI",
      "onAutoForward": "notify"
    },
    "6379": {
      "label": "Redis",
      "onAutoForward": "notify"
    },
    "5432": {
      "label": "PostgreSQL",
      "onAutoForward": "notify"
    }
  }
}
