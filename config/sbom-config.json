{
  "metadata": {
    "name": "10X Enterprise Enhancements",
    "description": "Supply Chain Security Configuration - SBOM Generation",
    "lifecycle": {
      "phase": "P2-Safety"
    }
  },
  "sbom": {
    "spec_version": "1.4",
    "format": "spdx-json",
    "include_transitive": true,
    "include_dev_dependencies": false,
    "components": [
      {
        "type": "application",
        "scope": "services"
      },
      {
        "type": "library",
        "scope": "dependencies"
      },
      {
        "type": "container",
        "scope": "docker-images"
      },
      {
        "type": "firmware",
        "scope": "Infrastructure"
      }
    ]
  },
  "generation": {
    "tools": [
      {
        "name": "syft",
        "version": ">=0.65.0",
        "purpose": "Generate SBOM from container images and source"
      },
      {
        "name": "cyclonedx",
        "version": ">=4.0.0",
        "purpose": "Generate CycloneDX format SBOM"
      }
    ],
    "frequency": "on-build",
    "triggers": [
      "docker-build",
      "release",
      "security-scan"
    ]
  },
  "distribution": {
    "locations": [
      {
        "type": "artifact-registry",
        "path": "sbom/",
        "format": "spdx-json"
      },
      {
        "type": "github-releases",
        "format": "spdx-json"
      },
      {
        "type": "oci-registry",
        "format": "cyclonedx"
      }
    ]
  },
  "validation": {
    "schema_validation": true,
    "component_inventory": true,
    "dependency_check": true,
    "vulnerability_scan": true
  }
}
