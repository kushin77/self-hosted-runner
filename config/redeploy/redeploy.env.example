# 100X Redeploy Standard Configuration
# Copy to config/redeploy/redeploy.env and customize per environment.

# Domain and naming standards
DOMAIN_NAME=elevatediq.ai
DOMAIN_PREFIX=elevatediq
ENVIRONMENT=production

# Deployment controls
DRY_RUN=true
ENFORCE_DOMAIN=true
ENFORCE_NAMING=true
ENFORCE_TEMPLATE_ENV=true
ENFORCE_SECURITY=true
ENFORCE_GOVERNANCE=true

# Infra settings
TARGET_WORKER_HOST=192.168.168.42
FORBIDDEN_DEV_HOST=192.168.168.31
NAS_HOST=192.168.168.100
NAS_PATH=/home/svc-nas/repositories/iac

# Backup policy settings
GCP_ARCHIVE_BUCKET=gs://elevatediq-ai-archive
INCREMENTAL_RETENTION_DAYS=14
WEEKLY_FULL_RETENTION_DAYS=30
WEEKLY_FULL_DAY=Sun

# Shared structure enforcement
SHARED_DIRS=scripts/lib,scripts/redeploy,config/redeploy,docs/redeploy,reports/redeploy
REQUIRED_TEMPLATE_FILES=.env.example,config/.env.example,frontend/.env.example,portal/docker/.env.example

# GitHub governance
REPO_OWNER=kushin77
REPO_NAME=self-hosted-runner
GITHUB_EPIC_TITLE="[EPIC] 100X Redeploy and Go-Live Readiness"
GITHUB_LABELS=governance,redeploy,go-live,automation

# Optional deployment command list. One command per line.
# If empty, defaults from scripts/redeploy/redeploy-100x.sh are used.
# DEPLOY_COMMANDS="bash scripts/utilities/pre-deployment-readiness-probe.sh\nbash scripts/k8s-health-checks/orchestrate-deployment.sh\nbash scripts/deployment-runbook.sh\nbash scripts/test/post_deploy_validation.sh"
