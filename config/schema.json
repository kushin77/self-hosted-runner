{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "10X Configuration Schema",
  "description": "Centralized configuration schema for 10X Enterprise Enhancements (P2 Safety)",
  "type": "object",
  "required": [
    "environment",
    "version",
    "deployment"
  ],
  "properties": {
    "environment": {
      "type": "string",
      "enum": [
        "development",
        "staging",
        "production"
      ],
      "description": "Deployment environment"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Configuration version (semver)"
    },
    "deployment": {
      "type": "object",
      "required": [
        "branch",
        "region",
        "strategy"
      ],
      "properties": {
        "branch": {
          "type": "string",
          "description": "Git branch for deployment",
          "examples": [
            "main",
            "staging",
            "dev"
          ]
        },
        "region": {
          "type": "string",
          "description": "Cloud region",
          "enum": [
            "us-east-1",
            "us-west-2",
            "eu-west-1",
            "ap-northeast-1"
          ]
        },
        "strategy": {
          "type": "string",
          "enum": [
            "blue-green",
            "canary",
            "rolling",
            "recreate"
          ],
          "description": "Deployment strategy"
        }
      }
    },
    "secrets": {
      "type": "object",
      "description": "Secret management configuration",
      "properties": {
        "backend": {
          "type": "string",
          "enum": [
            "vault",
            "gsm",
            "kms",
            "multi"
          ],
          "description": "Secrets backend"
        },
        "vault": {
          "type": "object",
          "properties": {
            "address": {
              "type": "string",
              "format": "uri",
              "description": "Vault server address"
            },
            "namespace": {
              "type": "string",
              "description": "Vault namespace (Enterprise)"
            },
            "auth_method": {
              "type": "string",
              "enum": [
                "jwt",
                "oidc",
                "approle",
                "kubernetes"
              ]
            }
          }
        },
        "gsm": {
          "type": "object",
          "properties": {
            "project_id": {
              "type": "string",
              "description": "Google Cloud project ID"
            },
            "kms_key": {
              "type": "string",
              "description": "GCP KMS key resource name"
            }
          }
        },
        "kms": {
          "type": "object",
          "properties": {
            "key_id": {
              "type": "string",
              "description": "AWS KMS key ID or ARN"
            },
            "region": {
              "type": "string",
              "description": "AWS region"
            }
          }
        }
      }
    },
    "observability": {
      "type": "object",
      "description": "Monitoring and observability configuration",
      "properties": {
        "logging": {
          "type": "object",
          "properties": {
            "level": {
              "type": "string",
              "enum": [
                "debug",
                "info",
                "warn",
                "error"
              ]
            },
            "format": {
              "type": "string",
              "enum": [
                "json",
                "text",
                "structured"
              ]
            }
          }
        },
        "metrics": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "interval": {
              "type": "string",
              "pattern": "^[0-9]+(s|m|h)$"
            }
          }
        },
        "tracing": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "sample_rate": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        }
      }
    },
    "security": {
      "type": "object",
      "description": "Security configuration",
      "properties": {
        "encryption": {
          "type": "object",
          "properties": {
            "at_rest": {
              "type": "boolean"
            },
            "in_transit": {
              "type": "boolean"
            },
            "algorithm": {
              "type": "string",
              "enum": [
                "AES-256",
                "ChaCha20"
              ]
            }
          }
        },
        "tls": {
          "type": "object",
          "properties": {
            "version": {
              "type": "string",
              "enum": [
                "1.2",
                "1.3"
              ]
            },
            "certificate_path": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
