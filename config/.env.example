## Example environment file for local/production deployment
# Copy to `.env` and fill real secrets. Do NOT commit `.env`.

# Database
POSTGRES_PASSWORD=replace_with_postgres_password

# Redis
REDIS_PASS=replace_with_redis_password

# Grafana
GRAFANA_PASS=replace_with_grafana_password

# Other optional overrides
API_HOST_PORT=18080
FRONTEND_HOST_PORT=13000
CACHE_HOST_PORT=16379
PROMETHEUS_HOST_PORT=19090
