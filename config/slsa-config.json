{
  "metadata": {
    "name": "10X Enterprise - SLSA Provenance",
    "description": "Supply Chain Levels for Software Artifacts (SLSA) Configuration",
    "lifecycle": {
      "phase": "P2-Safety",
      "level": "SLSA-L3"
    }
  },
  "slsa": {
    "version": "1.0",
    "level": 3,
    "requirements": {
      "version_control": {
        "required": true,
        "vcs": "git",
        "retention": "permanent"
      },
      "build": {
        "required": true,
        "platforms": [
          "github-actions"
        ],
        "process": "fully-scripted",
        "isolation": "container-based"
      },
      "provenance": {
        "required": true,
        "format": "in-toto/json",
        "includes_materials": true,
        "includes_reproducibility_info": true
      },
      "signing": {
        "algorithm": "ed25519",
        "key_management": "vault",
        "signer_identity": "service-account@system"
      }
    }
  },
  "provenance_generation": {
    "tools": [
      {
        "name": "slsa-provenance-action",
        "version": ">=1.9.0",
        "purpose": "Generate SLSA provenance attestations"
      },
      {
        "name": "in-toto",
        "version": ">=1.0.0",
        "purpose": "Create and verify in-toto link metadata"
      }
    ],
    "build_events": [
      "git-push",
      "release-tag",
      "manual-trigger"
    ],
    "retention": {
      "duration": "permanent",
      "location": "artifact-registry"
    }
  },
  "verification": {
    "methods": [
      {
        "name": "provenance-verifier",
        "validates": "SLSA provenance attestation"
      },
      {
        "name": "in-toto-verify",
        "validates": "in-toto link metadata chains"
      }
    ],
    "policies": {
      "reject_unverified": true,
      "require_all_signers": true,
      "require_minimum_review_count": 2
    }
  },
  "attestation": {
    "formats": [
      "slsav1",
      "intoto-v0.1"
    ],
    "signing_certs": {
      "issuer": "https://token.actions.githubusercontent.com",
      "subject": "githubworkflow"
    },
    "include_materials": {
      "git_uri": true,
      "git_digest": "sha256",
      "environment_variables": true,
      "command_invocation": true
    }
  },
  "key_management": {
    "backend": "vault",
    "key_rotation": {
      "interval": "90-days",
      "algorithm": "ed25519"
    },
    "ceremony": {
      "type": "automated",
      "guardian_threshold": 1
    }
  }
}
