{
  "title": "RunnerCloud OTEL Overview (Datadog)",
  "description": "Minimal dashboard showcasing job rates and latency via Datadog OTEL exporter",
  "widgets": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Jobs Processed",
      "requests": [
        { "q": "sum:provisioner_jobs_processed_total{*} by {service}" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "p95 Job Latency",
      "requests": [
        { "q": "p95:provisioner_job_processing_latency_ms{*}" }
      ]
    }
  ],
  "layout_type": "ordered",
  "is_read_only": true,
  "id": null,
  "template_variables": []
}