# ============================================================================
# NexusShield Portal Backend - Environment Configuration
# ============================================================================

# Deployment Target (PRODUCTION ONLY: 192.168.168.42)
DEPLOYMENT_HOST=192.168.168.42
DEPLOYMENT_ENV=production

# Server Configuration
NODE_ENV=production
PORT=3000
CORS_ORIGINS=http://192.168.168.42:3000,http://192.168.168.42:8000,http://192.168.168.42:3001

# Database Configuration (PostgreSQL on 192.168.168.42)
DATABASE_URL=postgresql://nexusshield:${REDACTED}@192.168.168.42:5432/nexusshield?schema=public

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Google Cloud Configuration
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/gcp-key.json

# Google Secret Manager (GSM)
GSM_ENABLED=true
GSM_PROJECT_ID=your-gcp-project-id

# HashiCorp Vault Configuration
VAULT_ENABLED=false
VAULT_ADDR=https://vault.example.com
REDACTED=your-vault-token
VAULT_NAMESPACE=nexusshield

# Google Cloud KMS Configuration
KMS_ENABLED=true
KMS_PROJECT_ID=your-gcp-project-id
KMS_KEY_RING=nexusshield-keys
KMS_KEY=primary

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json
AUDIT_LOG_PATH=/app/logs/portal-api-audit.jsonl

# Monitoring & Observability
PROMETHEUS_ENABLED=true
METRICS_PORT=9090

# Security
REQUIRE_HTTPS=true
SESSION_TIMEOUT=86400

# Database Connection Pool
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=20
