{
  "id": null,
  "uid": "job-flow",
  "title": "Provisioner Worker - Job Flow",
  "tags": ["p3","provisioner"],
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "type": "graph",
      "title": "Jobs Processed",
      "targets": [
        {
          "expr": "provisioner_jobs_processed_total",
          "legendFormat": "total",
          "refId": "A"
        }
      ],
      "datasource": null,
      "id": 1
    },
    {
      "type": "graph",
      "title": "Job Success Rate",
      "targets": [
        {
          "expr": "(provisioner_jobs_succeeded_total / provisioner_jobs_processed_total) * 100",
          "legendFormat": "success_rate",
          "refId": "A"
        }
      ],
      "datasource": null,
      "id": 2
    },
    {
      "type": "graph",
      "title": "Queue Depth",
      "targets": [
        {
          "expr": "provisioner_queue_depth",
          "legendFormat": "depth",
          "refId": "A"
        }
      ],
      "datasource": null,
      "id": 3
    },
    {
      "type": "graph",
      "title": "p95 Job Latency (ms)",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, provisioner_job_processing_latency_ms)",
          "legendFormat": "p95_latency",
          "refId": "A"
        }
      ],
      "datasource": null,
      "id": 4
    }
  ],
  "templating": {"list": []},
  "annotations": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
