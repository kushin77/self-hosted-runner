#!/usr/bin/env python3
"""
<REDACTED_SECRET_REMOVED_BY_AUTOMATION>
You can obtain `GITHUB_TOKEN` from GSM using `scripts/load_gsm_secrets.sh`.

Usage:
<REDACTED_SECRET_REMOVED_BY_AUTOMATION>
    # export GITHUB_TOKEN (redacted)
    # Then run: REPO=owner/repo python3 scripts/manage_github_issues.py create
    # Or to close: REPO=owner/repo python3 scripts/manage_github_issues.py close --title "Issue Title"

Commands:
  create  Create the standard infra issues (idempotent by title).
  close   Close an issue by title.
"""
import os
import sys
import json
from urllib import request, parse

GITHUB_API = "https://api.github.com"

def api_request(method, path, token, data=None):
    url = GITHUB_API + path
    headers = {
        'Authorization': f'token {token}',
        'Accept': 'application/vnd.github.v3+json',
        'User-Agent': 'infra-agent'
    }
    data_bytes = None
    if data is not None:
        data_bytes = json.dumps(data).encode('utf-8')
        headers['Content-Type'] = 'application/json'
    req = request.Request(url, data=data_bytes, headers=headers, method=method)
    with request.urlopen(req) as resp:
        return json.load(resp)


def find_issue_by_title(repo, token, title):
    q = parse.quote(f'repo:{repo} "{title}" in:title')
    path = f'/search/issues?q={q}'
    res = api_request('GET', path, token)
    for item in res.get('items', []):
        if item.get('title') == title:
            return item
    return None


def create_issue(repo, token, title, body):
    existing = find_issue_by_title(repo, token, title)
    if existing:
        print(f"Issue already exists: #{existing['number']} {title}")
        return existing
    path = f'/repos/{repo}/issues'
    data = {'title': title, 'body': body}
    res = api_request('POST', path, token, data)
    print(f"Created issue #{res['number']}: {title}")
    return res


def close_issue(repo, token, issue_number):
    path = f'/repos/{repo}/issues/{issue_number}'
    data = {'state': 'closed'}
    res = api_request('PATCH', path, token, data)
    print(f"Closed issue #{res['number']}")
    return res


def create_standard_issues(repo, token):
    issues = [
        ("Apply Terraform: GCP KMS & GCS for Vault (auto-unseal)",
         "Apply the Terraform in /terraform to provision KMS key ring, crypto key, and GCS bucket for Vault storage. Use the helper script ./scripts/terraform_apply.sh to run apply."),
        ("Configure Workload Identity Federation for GitHub Actions",
         "Create Workload Identity Pool/Provider and bind the Vault service account to allow OIDC-based impersonation. See docs/TODO_INFRA_ISSUES.md."),
        ("Final Production Test: Trivy Gate + Vault Auto-Unseal",
         "Run production deployment with real OIDC credentials, validate Trivy gating behavior and Vault auto-unseal. Follow acceptance criteria in docs/TODO_INFRA_ISSUES.md.")
    ]
    for title, body in issues:
        create_issue(repo, token, title, body)


def main():
    if len(sys.argv) < 2:
        print(__doc__)
        sys.exit(2)
    cmd = sys.argv[1]
    token = os.environ.get('GITHUB_TOKEN')
    repo = os.environ.get('REPO')
    if not token or not repo:
        print('ERROR: set GITHUB_TOKEN and REPO=owner/repo')
        sys.exit(2)
    if cmd == 'create':
        create_standard_issues(repo, token)
    elif cmd == 'close':
        if len(sys.argv) < 4 or sys.argv[2] != '--title':
            print('Usage: manage_github_issues.py close --title "Issue Title"')
            sys.exit(2)
        title = sys.argv[3]
        issue = find_issue_by_title(repo, token, title)
        if not issue:
            print('Issue not found')
            sys.exit(1)
        close_issue(repo, token, issue['number'])
    else:
        print('Unknown command')
        sys.exit(2)

if __name__ == '__main__':
    main()
