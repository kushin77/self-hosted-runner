[Unit]
Description=Job Cancellation Handler (Phase P1)
After=network.target

[Service]
Type=simple
User=runner
Group=runner
WorkingDirectory=/opt/runner
ExecStart=/opt/runner/handlers/job-cancellation-handler.sh wrapper runner_daemon /usr/local/bin/runner-job-loop
Restart=on-failure
RestartSec=5
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
