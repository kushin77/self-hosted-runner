[Unit]
Description=Provisioner Worker (container)
After=network.target

[Service]
Type=simple
Restart=on-failure
Environment=NODE_ENV=production
ExecStart=/usr/bin/podman run --rm --name provisioner-worker -p 9090:9090 provisioner-worker:latest
ExecStop=/usr/bin/podman stop provisioner-worker
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
