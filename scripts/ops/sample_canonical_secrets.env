# Sample environment file for canonical-secrets API
# Copy to /etc/canonical_secrets.env on the host and update values.

# Service listen address
HOST=0.0.0.0
PORT=8000

# Log level: debug/info/warn/error
LOG_LEVEL=info

# Provider configuration (example placeholders)
PRIMARY_PROVIDER=vault
GSM_PROJECT=your-gcp-project
VAULT_ADDR=https://vault.example.internal:8200
AWS_REGION=us-east-1

# Storage and audit
S3_BUCKET=your-immutable-bucket

# Credentials are fetched at runtime via scripts/ops/fetch_credentials.sh
