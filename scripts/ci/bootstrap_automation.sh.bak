#!/usr/bin/env bash
set -euo pipefail

# bootstrap_automation.sh
# Idempotent helper to perform the remaining automated steps that require credentials:
# - rotate GitHub deploy key and store private key in GitLab CI variable
# - set protected GitLab CI variables (S3 bucket, decryption keys, mirror repo)
# - create a GitLab pipeline schedule to run the backup job
#
# This script DOES NOT embed credentials. Provide required env vars at runtime.

usage(){
  cat <<EOF
Usage: GITLAB_API_URL=... GITLAB_API_TOKEN=... GITLAB_GROUP_ID=... GITHUB_REPO=org/repo \
       GITHUB_TOKEN=... RESTORE_S3_BUCKET=s3://bucket AGE_KEY_FILE_PATH=/path/to/age.key \
       ./scripts/ci/bootstrap_automation.sh

Required env vars:
  GITLAB_API_URL       - e.g. https://gitlab.example.com
  GITLAB_API_TOKEN     - token with api scope
  GITLAB_GROUP_ID      - numeric group id to store group-level CI variables (or PROJECT_ID)
  GITHUB_REPO          - target GitHub backup repo (owner/repo)
<REDACTED_SECRET_REMOVED_BY_AUTOMATION>
  RESTORE_S3_BUCKET    - s3://bucket/path
Optional:
  VAR_KEY              - name of CI var to store private SSH key (default: GITHUB_MIRROR_SSH_KEY)
  CRON                 - cron schedule for backup (default: "0 2 * * *" daily 02:00 UTC)
EOF
}

if [[ "${1:-}" =~ ^(-h|--help)$ ]]; then usage; exit 0; fi

: ${GITLAB_API_URL:?}
: ${GITLAB_API_TOKEN:?}
: ${GITLAB_GROUP_ID:?}
: ${GITHUB_REPO:?}
: ${GITHUB_TOKEN:?}
: ${RESTORE_S3_BUCKET:?}

VAR_KEY=${VAR_KEY:-GITHUB_MIRROR_SSH_KEY}
CRON=${CRON:-"0 2 * * *"}

SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)

echo "[bootstrap] Rotating GitHub deploy key and storing private key in GitLab variable ${VAR_KEY}"
export GITHUB_TOKEN
export GITLAB_API_URL
export GITLAB_API_TOKEN
export GROUP_ID=${GITLAB_GROUP_ID}
export GITHUB_REPO
export VAR_KEY

"${SCRIPT_DIR}/rotate_github_deploy_key.sh"

echo "[bootstrap] Setting protected CI variables in GitLab group ${GITLAB_GROUP_ID}"
"${SCRIPT_DIR}/gitlab_set_variable.sh" --scope group --id "${GITLAB_GROUP_ID}" --key RESTORE_S3_BUCKET --value "${RESTORE_S3_BUCKET}" --protected true --masked false

if [ -n "${AGE_KEY_FILE_PATH:-}" ] && [ -f "${AGE_KEY_FILE_PATH}" ]; then
  "${SCRIPT_DIR}/gitlab_set_variable.sh" --scope group --id "${GITLAB_GROUP_ID}" --key AGE_KEY_FILE --value "$(cat "${AGE_KEY_FILE_PATH}")" --protected true --masked true
fi

# Also set mirror repo path
"${SCRIPT_DIR}/gitlab_set_variable.sh" --scope group --id "${GITLAB_GROUP_ID}" --key GITHUB_MIRROR_REPO --value "${GITHUB_REPO}" --protected true --masked false

echo "[bootstrap] Creating scheduled pipeline to run maintenance:gitlab_backup"
# Create a project-level schedule. Requires PROJECT_ID environment if project-based; otherwise user can create in UI.
if [ -n "${GITLAB_PROJECT_ID:-}" ]; then
  SCHEDULE_PAYLOAD=$(jq -n --arg description "Daily GitLab backup" --arg ref "main" --arg cron "$CRON" '{description: $description, ref: $ref, cron: $cron}')
  curl -s --fail --request POST "${GITLAB_API_URL}/api/v4/projects/${GITLAB_PROJECT_ID}/pipeline_schedules" \
    --header "PRIVATE-TOKEN: ${GITLAB_API_TOKEN}" \
    --header "Content-Type: application/json" \
    --data "$SCHEDULE_PAYLOAD" || echo "Failed to create project schedule via API; consider creating it in UI"
else
  echo "GITLAB_PROJECT_ID not set; skipping automatic API schedule creation. Please create a schedule in the GitLab UI for the repository running `maintenance:gitlab_backup`."
fi

echo "[bootstrap] Completed. Verify group variables and pipeline schedule in GitLab UI."
