#!/usr/bin/env bash
set -euo pipefail

# Prototype: Renew Vault token and re-fetch registry credentials periodically.
# This is a simple loop that renews the token and re-logs into the registry when needed.

RENEW_INTERVAL_SECONDS=${RENEW_INTERVAL_SECONDS:-300}
VAULT_ADDR=${VAULT_ADDR:-}

if [[ -z "${VAULT_ADDR:-}" ]]; then
  echo "VAULT_ADDR not set; aborting renewal loop"
  exit 1
fi

if [[ -z "${VAULT_TOKEN:-}" ]]; then
<REDACTED_SECRET_REMOVED_BY_AUTOMATION>
  exit 1
fi

while true; do
  echo "Attempting to renew Vault token..."
  resp=$(curl -fsS --header "X-Vault-Token: $VAULT_TOKEN" -X POST "$VAULT_ADDR/v1/auth/token/renew-self" || true)
  if echo "$resp" | grep -q 'errors'; then
    echo "Token renew failed; re-login required"
    exit 2
  else
    echo "Token renewed"
  fi

  # Optionally re-fetch registry secrets and docker login
  reg=$(curl -fsS --header "X-Vault-Token: $VAULT_TOKEN" "$VAULT_ADDR/v1/secret/data/registries/staging" || true)
  REG_USER=$(echo "$reg" | jq -r '.data.data.username // empty')
  REG_PASS=$(echo "$reg" | jq -r '.data.data.password // empty')
  if [[ -n "$REG_USER" && -n "$REG_PASS" ]]; then
    echo "Refreshing docker login for $REG_USER"
    echo "$REG_PASS" | docker login -u "$REG_USER" --password-stdin ${TARGET_REGISTRY:-registry-staging.example.com} || true
  fi

  sleep "$RENEW_INTERVAL_SECONDS"
done
