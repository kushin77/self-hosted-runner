# NexusShield Security Framework
# ==============================

# Sensitive data (never commit)
nexusshield/config/*.secret.yml
nexusshield/config/*.key
nexusshield/config/*.pem
nexusshield/credentials/*
!nexusshield/credentials/.gitkeep

# Runtime artifacts
nexusshield/logs/*.jsonl
nexusshield/cache/*
nexusshield/tmp/*
*.pyc
__pycache__/

# Sensitive outputs
*.enc
*.encrypted
.env
.env.local
docker-compose.override.yml
docker-compose.secrets.yml
.env.local
.vault-token

# IDE/Editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Build artifacts
dist/
build/
*.egg-info/

# NexusShield runtime & secrets (ignore generated runtime artifacts)
nexusshield/.credentials-config
nexusshield/logs/*.jsonl
deployment-execution-*.log
logs/portal-mvp-phase*.jsonl
fix-audit-logs.sh

# Secrets and runtime artifacts
.ssh/
terraform/terraform.tfstate
terraform/.terraform.tfstate.lock.info
infra/credentials/
.nexusshield_credentials

# Terraform files (build artifacts, not source)
**/.terraform/
**/.terraform.lock.hcl
**/*.tfstate
**/*.tfstate.backup
**/*terraform.tfstate*

# Local credentials (do not commit)
.credentials/
nexusshield/*/terraform/*.log
logs/
PHASE*_*.md
scripts/deploy-with-secrets.sh
nexusshield/infrastructure/terraform/production/logs/

# Node modules (should not be committed)
node_modules/
frontend/node_modules/

# Audit logs and runtime summaries
scripts/audit/
*.summary.log

# Credential examples and templates (use GSM/Vault/KMS instead)
scripts/**/*secret*.sh
scripts/**/*credential*.sh
scripts/**/*provision*.sh
!scripts/deployment/hands-off-final-provisioning.sh
scripts/**/deploy-with-secrets.sh
scripts/**/apply-*.sh
scripts/**/fetch-*.sh
scripts/**/migrate-*.sh
scripts/**/redact-*.sh
docs/**/*.md.bak

**/*.jsonl
**/*.log
**/*.bak
**/*.plan
**/*.tfstate*
config/docker-compose.phase6.yml
# Ignore logs, backups, and sensitive artifacts
**/*.jsonl
**/*.log
**/*.bak
**/*.plan
**/*.tfstate*
/*.tfplan
config/docker-compose.phase6.yml
secrets/
*.key
*.pem
scripts/deployment/provision-operator-credentials.sh
scripts/gcp/*.sh
terraform/terraform.tfvars
terraform/*.backup
