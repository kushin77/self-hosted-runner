# NexusShield Security Framework
# ==============================

# CRITICAL: Sensitive data (never commit)
nexusshield/config/*.secret.yml
nexusshield/config/*.key
nexusshield/config/*.pem
nexusshield/credentials/*
!nexusshield/credentials/.gitkeep

# Credential & secrets files (BLOCKING PATTERNS)
*.env
*.env-*
*.env.*
!.env.example
!.env.template
.secrets/
secrets.json
secrets.yaml
credentials.json
*service-account*.json
*private*.key
*.pem
*.key
.aws/credentials
.aws/config
.kube/config
terraform.tfvars
*.tfvars
.vault-token
.vault-addr
vault-token

# AWS & Cloud credentials
aws_access_key*
aws_secret*
cloud-credentials*

# GitHub tokens & credentials
github_token
.github-token
gh_token

# API keys & tokens (catch-all patterns)
*api_key*
*api_secret*
*secret_key*
*private_key*
*access_token*
*refresh_token*
*bearer_token*
*api_token*

# Database & service credentials
db_password
database_password
mysql_password
postgres_password
mongodb_password
redis_password
db_conn_string
connection_string

# SSL/TLS certificates & keys
*.crt
*.key
*.pem
*.p12
*.pfx
cacert.pem

# SSH keys
ssh_key*
id_rsa*
id_ecdsa*
id_ed25519*

# Runner keys (local self-hosted runner private keys)
.runner-keys/

# Explicitly ignore signing key moved to GSM
signing_key.pem

# Runtime artifacts & logs (never commit)
logs/
artifacts/
backups/
*.log
*.jsonl
nexusshield/logs/*.jsonl
nexusshield/cache/*
nexusshield/tmp/*
*.pyc
__pycache__/

# Build/deployment artifacts
dist/
build/
*.egg-info/
.pytest_cache/
.coverage
htmlcov/

# Encrypted/sensitive outputs
*.enc
*.encrypted
*.gpg
docker-compose.override.yml
docker-compose.secrets.yml

# Sensitive audit trails & temporary files
audit-*.jsonl
setup-*.jsonl
*-setup-*.jsonl
tmp/
.tmp/
temp/

# IDE/Editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Build artifacts
dist/
build/
*.egg-info/

# NexusShield runtime & secrets
nexusshield/.credentials-config
deployment-execution-*.log
logs/portal-mvp-phase*.jsonl
fix-audit-logs.sh

# Secrets and runtime artifacts
.ssh/
terraform/terraform.tfstate
terraform/.terraform.tfstate.lock.info
infra/credentials/
.nexusshield_credentials

# Terraform files (build artifacts, not source)
**/.terraform/
**/.terraform.lock.hcl
**/*.tfstate
**/*.tfstate.backup
**/*terraform.tfstate*

# Local credentials (do not commit)
.credentials/
nexusshield/*/terraform/*.log
logs/
PHASE*_*.md
scripts/deploy-with-secrets.sh
nexusshield/infrastructure/terraform/production/logs/

# Node modules (should not be committed)
node_modules/
frontend/node_modules/

# Audit logs and runtime summaries
scripts/audit/
*.summary.log

# Encrypted/sensitive outputs
*.enc

# Template and example env files that may contain credential patterns
secrets.env.template
backend/.env.example
backend/README.md.bak2
docs/PHASE_3B_CREDENTIAL_INJECTION_GUIDE.md.bak2
docs/deployment/CREDENTIAL_PROVISIONING_RUNBOOK.md.bak2

# Credential documentation archives
docs/archive/*CREDENTIAL*.md
docs/*CREDENTIAL*.md
docs/governance/*CREDENTIAL*.md
**/*.log
.venv

# Security scan reports (contains sensitive vulnerability/credential findings)
gitleaks-report.json
*-scan-report.json
*-security-report.json
*.scan.json
backups/secret_deployer-sa-key.txt
