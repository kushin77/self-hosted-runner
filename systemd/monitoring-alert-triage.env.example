# Copy to /etc/default/monitoring-alert-triage and adjust for your environment.
# Prefer GSM over plaintext token values.

PROM_URL=http://127.0.0.1:9090
AM_URL=http://127.0.0.1:9093
# Optional fallback endpoints used when primary URLs are unreachable.
# PROM_URL_FALLBACK=https://prometheus.example.com
# AM_URL_FALLBACK=https://alertmanager.example.com
# Optional GSM-backed endpoint URLs (secret payload should be full URL).
# PROM_URL_GSM_SECRET=prometheus-endpoint-url
# AM_URL_GSM_SECRET=alertmanager-endpoint-url
GITHUB_REPOSITORY=kushin77/self-hosted-runner

# GSM-backed token retrieval
GCP_PROJECT_ID=nexusshield-prod
GITHUB_TOKEN_GSM_SECRET=github-token

# Optional wrapper controls
# Raise warning artifact after this many consecutive triage skips.
TRIAGE_SKIP_ALERT_THRESHOLD=3
# Keep at most this many lines in logs/monitoring-alert-issue-triage.jsonl.
TRIAGE_AUDIT_MAX_LINES=5000
# If true, triage script failures make the service fail; default false keeps fail-safe no-op behavior.
TRIAGE_STRICT_MODE=false

# Optional direct token override (not recommended)
# GITHUB_TOKEN=ghp_xxx
