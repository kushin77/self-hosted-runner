#!/bin/bash
BRANCH=$(git rev-parse --abbrev-ref HEAD)

# Check if branch matches protected branches (main, develop, release/*)
if [[ "$BRANCH" == "main" ]] || [[ "$BRANCH" == "master" ]] || [[ "$BRANCH" == "develop" ]] || [[ "$BRANCH" == release/* ]]; then
  exit 0
fi

# Check if branch matches TYPE/TICKET-description pattern
if [[ ! "$BRANCH" =~ ^[a-z]+/ ]]; then
  echo "❌ Branch name '$BRANCH' violates naming convention"
  echo "   Format: TYPE/TICKET-description (e.g., feature/INFRA-401-oauth)"
  echo "   Valid types: feature, fix, docs, refactor, perf, ci, test, chore, security"
  exit 1
fi
