# Frontend Configuration for NexusShield Portal

# API Base URL - Runtime ephemeral fetch (no caching)
REACT_APP_API_URL=http://localhost:3000

# OAuth 2.0 Credentials (ephemeral, fetched at login)
REACT_APP_OAUTH_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
REACT_APP_OAUTH_GITHUB_CLIENT_ID=your-github-oauth-client-id

# Environment Configuration
REACT_APP_ENVIRONMENT=development
REACT_APP_LOG_LEVEL=debug

# Feature Flags
REACT_APP_FEATURE_DARK_MODE=true
REACT_APP_FEATURE_EXPORT_AUDIT=true
REACT_APP_FEATURE_CREDENTIAL_ROTATION=true
REACT_APP_FEATURE_COMPLIANCE_DASHBOARD=true

# Session Management (ephemeral only)
REACT_APP_SESSION_TIMEOUT_MINUTES=24
REACT_APP_TOKEN_REFRESH_INTERVAL_SECONDS=3600

# Monitoring
REACT_APP_SENTRY_DSN=
REACT_APP_ENABLE_ANALYTICS=false
