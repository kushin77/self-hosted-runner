FROM python:3.14-alpine

# Build arguments for immutable backup metadata
ARG BUILD_VERSION=1.0.0
ARG BUILD_DATE=unknown
ARG BUILD_COMMIT_SHA=unknown
ARG BUILD_COMMIT_REF=unknown
ARG BUILD_CHECKSUM=unknown

# Metadata labels (distributed across all systems for disaster recovery)
LABEL \
    backup.version="${BUILD_VERSION}" \
    backup.date="${BUILD_DATE}" \
    backup.commit.sha="${BUILD_COMMIT_SHA}" \
    backup.commit.ref="${BUILD_COMMIT_REF}" \
    backup.rto.minutes="15" \
    backup.rpo.hours="1" \
    backup.retention.days="84" \
    backup.checksum="${BUILD_CHECKSUM}" \
    backup.source.repo="https://github.com/kushin77/self-hosted-runner" \
    org.opencontainers.image.created="${BUILD_DATE}" \
    org.opencontainers.image.revision="${BUILD_COMMIT_SHA}" \
    org.opencontainers.image.source="https://github.com/kushin77/self-hosted-runner" \
    org.opencontainers.image.title="app-backup" \
    org.opencontainers.image.description="Immutable disaster recovery backup image"

# Install minimal runtime dependencies
RUN apk add --no-cache \
    bash \
    curl \
    jq \
    git \
    openssl \
    ca-certificates

# Create recovery working directory
WORKDIR /recovery

# Copy recovery scripts and documentation
COPY scripts/recover-from-nuke.sh scripts/verify-recovery.sh ./
COPY scripts/get-secret-with-fallback.sh scripts/check-secret-health.sh ./
# COPY DOCKER_HUB_BACKUP_AND_DR_STRATEGY.md ./docs/ || true

# Copy backup metadata and git information
# COPY .backup-metadata/ ./metadata/ || true
# COPY .git/ ./git/ || true

# Ensure scripts are executable
RUN chmod +x *.sh

# Health check - verify recovery tools are available
HEALTHCHECK --interval=5m --timeout=30s --start-period=10s --retries=3 \
    CMD test -f recover-from-nuke.sh && test -f verify-recovery.sh && \
        gcloud secrets list >/dev/null 2>&1 || exit 0

# Default command - display recovery information
ENTRYPOINT ["/bin/bash"]
CMD ["-c", "echo 'Recovery image ready. Run: /recovery/recover-from-nuke.sh <backup-tag>' && bash"]

# Labels for recovery bootstrap
LABEL \
    keepalive="true" \
    recovery.type="immutable-backup" \
    recovery.bootstrap="manual"
