{
  "description": "Credential rotation configuration - immutable, ephemeral, idempotent",
  "rotation_schedule": "0 3 * * * UTC",
  "cleanup_schedule": "0 4 * * * UTC",
  "verification_schedule": "0 5 * * * UTC",
  "credentials": [
    {
      "id": "github-pat-core",
      "provider": "gsm",
      "interval_hours": 24,
      "notify": ["slack"],
      "workflows": [
        ".github/workflows/phase3-production-deploy.yml",
        ".github/workflows/ci-cd-security.yml"
      ]
    },
    {
      "id": "gcp-service-account",
      "provider": "gsm",
      "interval_hours": 24,
      "notify": ["slack", "email"],
      "workflows": [
        ".github/workflows/phase3-production-deploy.yml",
        ".github/workflows/gcp-infrastructure-deploy.yml"
      ]
    },
    {
      "id": "vault-root-token",
      "provider": "vault",
      "interval_hours": 168,
      "notify": ["slack", "pagerduty"],
      "workflows": [
        ".github/workflows/secrets-rotation.yml"
      ]
    },
    {
      "id": "aws-credentials",
      "provider": "aws",
      "interval_hours": 24,
      "notify": ["slack"],
      "workflows": [
        ".github/workflows/aws-oidc-infrastructure.yml"
      ]
    },
    {
      "id": "slack-bot-token",
      "provider": "gsm",
      "interval_hours": 72,
      "notify": ["slack"],
      "workflows": [
        ".github/workflows/slack-notifications.yml"
      ]
    },
    {
      "id": "pagerduty-api-key",
      "provider": "vault",
      "interval_hours": 72,
      "notify": ["slack"],
      "workflows": [
        ".github/workflows/incident-management.yml"
      ]
    }
  ]
}
