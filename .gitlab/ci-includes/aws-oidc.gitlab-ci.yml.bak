# GitLab CI — AWS OIDC Authentication Include
# GAP-001 FIX: Portable OIDC auth for GitLab pipelines (mirrors GitHub id-token: write pattern)
# Include via:  include: - local: '.gitlab/ci-includes/aws-oidc.gitlab-ci.yml'
# NIST Controls: AC-2, IA-2, SA-10

# ---------------------------------------------------------------------------
# Hidden job template — extend with `extends: .aws_oidc_auth`
# ---------------------------------------------------------------------------
.aws_oidc_auth:
  id_tokens:
    AWS_OIDC_TOKEN:
      aud: ${CI_SERVER_URL}         # must match client_id_list in Terraform module
  before_script:
    - |
      echo "[OIDC] Exchanging GitLab JWT for AWS STS credentials..."
      export $(aws sts assume-role-with-web-identity \
        --role-arn "${AWS_ROLE_ARN}" \
        --role-session-name "gitlab-ci-${CI_JOB_ID}" \
        --web-identity-token "${AWS_OIDC_TOKEN}" \
        --duration-seconds "${AWS_SESSION_DURATION:-3600}" \
        --query 'Credentials.[AccessKeyId,SecretAccessKey,SessionToken]' \
        --output text | awk '{print "AWS_ACCESS_KEY_ID="$1"\nAWS_SECRET_ACCESS_KEY="$2"\nAWS_SESSION_TOKEN="$3}')
      echo "AWS_DEFAULT_REGION=${AWS_REGION:-us-east-1}" >> ${GITLAB_ENV:-/dev/null}
      aws sts get-caller-identity  # Verify (fails fast on bad creds)
  variables:
    # Override these per-job or via GitLab CI/CD Variables UI
    AWS_ROLE_ARN: ${GITLAB_CI_AWS_ROLE_ARN}   # set in GitLab → Settings → CI/CD → Variables
    AWS_REGION: ${GITLAB_CI_AWS_REGION:-us-east-1}

# ---------------------------------------------------------------------------
# GCP Workload Identity Federation template — extend with `.gcp_oidc_auth`
# ---------------------------------------------------------------------------
.gcp_oidc_auth:
  id_tokens:
    GCP_OIDC_TOKEN:
      aud: ${GCP_WORKLOAD_IDENTITY_PROVIDER}
  before_script:
    - |
      echo "[OIDC] Exchanging GitLab JWT for GCP access token..."
      echo "${GCP_OIDC_TOKEN}" > /tmp/gcp-oidc-token.json
      gcloud auth login --cred-file=/tmp/gcp-oidc-token.json --quiet
      gcloud config set project "${GCP_PROJECT_ID}"
      rm -f /tmp/gcp-oidc-token.json
  variables:
    GCP_WORKLOAD_IDENTITY_PROVIDER: ${GITLAB_CI_GCP_WIF_PROVIDER}
    GCP_PROJECT_ID: ${GITLAB_CI_GCP_PROJECT_ID}

# ---------------------------------------------------------------------------
# Vault OIDC Authentication template — extend with `.vault_oidc_auth` [NIST-IA-5]
# ---------------------------------------------------------------------------
.vault_oidc_auth:
  id_tokens:
    VAULT_OIDC_TOKEN:
      aud: ${CI_SERVER_URL}
  before_script:
    - |
      echo "[OIDC] Logging into HashiCorp Vault via GitLab JWT..."
      if command -v vault >/dev/null; then
        export VAULT_TOKEN=$(vault write -field=token auth/${VAULT_AUTH_PATH:-gitlab}/login \
          role="${VAULT_ROLE:-gitlab-ci-reader}" \
          jwt="${VAULT_OIDC_TOKEN}")
        echo "Vault token acquired for role: ${VAULT_ROLE:-gitlab-ci-reader}"
        vault token lookup
      else
        echo "Vault CLI not found — skipping login"
      fi
  variables:
    VAULT_ADDR: ${VAULT_ADDR:-https://vault.internal.elevatediq.com}
    VAULT_AUTH_PATH: "gitlab"
    VAULT_ROLE: "gitlab-ci-reader"
