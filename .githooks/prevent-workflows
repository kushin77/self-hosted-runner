#!/bin/sh
# Prevent adding or modifying GitHub Actions workflows
# Exit non-zero to block commits touching .github/workflows/*
if git rev-parse --verify HEAD >/dev/null 2>&1; then
  against=HEAD
else
  # Initial commit; diff against empty tree
  against=4b825dc642cb6eb9a060e54bf8d69288fbee4904
fi
files=$(git diff --cached --name-only --diff-filter=ACM "$against")
for f in $files; do
  case "$f" in
    .github/workflows/*)
      echo "ERROR: Commits modifying .github/workflows/ are prohibited by repository policy."
      echo "Use the direct deployment framework (scripts/deployment/) instead."
      exit 1
      ;;
  esac
done
exit 0
#!/usr/bin/env bash
set -euo pipefail

# Prevent adding GitHub workflow files to commits (local safety guard)
STAGED=$(git diff --cached --name-only)
if echo "$STAGED" | grep -q "^.github/workflows/"; then
  echo "ERROR: committing files under .github/workflows is disallowed by repository policy." >&2
  echo "If you are an admin and need to add a workflow, coordinate via admin channel and update policy." >&2
  exit 1
fi

exit 0
