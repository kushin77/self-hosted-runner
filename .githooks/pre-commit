#!/bin/bash
# 10X PRE-COMMIT ENFORCEMENT HOOK
# Validates immutability, manifests, credentials, and integrity before commit
# Prevents plaintext secrets, enforces manifest schema, validates versions

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo "🔒 Running 10X Pre-Commit Enforcement Validation..."

FAILED=0
CHECKS_PASSED=0
CHECKS_FAILED=0

# Check 1: No plaintext secrets in diffs
echo -n "Checking for plaintext secrets... "
if git diff --cached | grep -iE "(password|token|secret|api_key|aws_secret|private_key)" > /dev/null 2>&1; then
    echo -e "${RED}FAIL${NC}"
    echo "❌ Plaintext credentials detected in diff:"
    git diff --cached | grep -iE "(password|token|secret|api_key|aws_secret|private_key)" | head -5
    CHECKS_FAILED=$((CHECKS_FAILED + 1))
    FAILED=1
else
    echo -e "${GREEN}PASS${NC}"
    CHECKS_PASSED=$((CHECKS_PASSED + 1))
fi

# Check 2: Validate action manifests
echo -n "Validating action manifests... "
MANIFEST_COUNT=0
MANIFEST_VALID=0

for manifest in $(git diff --cached --name-only | grep "action-manifest.json"); do
    MANIFEST_COUNT=$((MANIFEST_COUNT + 1))
    
    # Validate JSON
    if ! git show :"$manifest" | python3 -m json.tool > /dev/null 2>&1; then
        echo -e "${RED}FAIL${NC} - Invalid JSON: $manifest"
        CHECKS_FAILED=$((CHECKS_FAILED + 1))
        FAILED=1
        continue
    fi
    
    # Validate required fields
    CONTENT=$(git show :"$manifest")
    if ! echo "$CONTENT" | python3 << 'PYEOF'
import json, sys, re
try:
    m = json.load(sys.stdin)
    
    # Required fields
    required = ['version', 'integrity_hash', 'lifecycle_state', 'debug_cycle', 'credentials_provider']
    missing = [f for f in required if f not in m]
    if missing:
        print(f"Missing fields: {missing}")
        sys.exit(1)
    
    # Validate formats
    if not re.match(r'^v\d+\.\d+\.\d+', m['version']):
        print(f"Invalid version format: {m['version']}")
        sys.exit(1)
    
    if not re.match(r'^[a-f0-9]{12}$', m['integrity_hash']):
        print(f"Invalid integrity hash format: {m['integrity_hash']}")
        sys.exit(1)
    
    if m['lifecycle_state'] not in ['ACTIVE', 'ARCHIVED', 'REBUILDING', 'QUARANTINED']:
        print(f"Invalid lifecycle_state: {m['lifecycle_state']}")
        sys.exit(1)
    
    if not isinstance(m['debug_cycle'], int) or m['debug_cycle'] < 0:
        print(f"Invalid debug_cycle: {m['debug_cycle']}")
        sys.exit(1)
    
    if m['credentials_provider'] not in ['GSM', 'VAULT', 'KMS']:
        print(f"Invalid credentials_provider: {m['credentials_provider']}")
        sys.exit(1)
PYEOF
    then
        echo -e "${RED}FAIL${NC} - Schema validation error: $manifest"
        CHECKS_FAILED=$((CHECKS_FAILED + 1))
        FAILED=1
    else
        MANIFEST_VALID=$((MANIFEST_VALID + 1))
    fi
done

if [ $MANIFEST_COUNT -gt 0 ]; then
    echo -e "${GREEN}PASS${NC} ($MANIFEST_VALID/$MANIFEST_COUNT valid)"
    CHECKS_PASSED=$((CHECKS_PASSED + 1))
fi

# Check 3: No direct action.yml modifications for versioned actions
echo -n "Preventing direct action.yml modifications... "
DIRECT_MODS=0

for action_yml in $(git diff --cached --name-only | grep -E "\.github/actions/.*/action\.yml$"); do
    action_dir=$(dirname "$action_yml")
    manifest_file="$action_dir/action-manifest.json"
    
    # If manifest exists, action.yml should NOT be directly modified
    if [ -f "$manifest_file" ]; then
        echo -e "${RED}FAIL${NC}"
        echo "❌ Direct modification of action.yml detected: $action_yml"
        echo "   Use rebuild cycle instead of manual edits"
        CHECKS_FAILED=$((CHECKS_FAILED + 1))
        FAILED=1
        DIRECT_MODS=$((DIRECT_MODS + 1))
    fi
done

if [ $DIRECT_MODS -eq 0 ]; then
    echo -e "${GREEN}PASS${NC}"
    CHECKS_PASSED=$((CHECKS_PASSED + 1))
fi

# Check 4: Validate version increments
echo -n "Validating version increments... "
VERSION_CHECK=0

for manifest in $(git diff --cached --name-only | grep "action-manifest.json"); do
    NEW=$(git show :"$manifest" | python3 -c "import sys, json; print(json.load(sys.stdin).get('version', ''))")
    
    if [ -z "$NEW" ]; then
        continue
    fi
    
    # Extract previous version from git
    OLD=$(git show HEAD:"$manifest" 2>/dev/null | python3 -c "import sys, json; print(json.load(sys.stdin).get('version', ''))" || echo "")
    
    if [ -z "$OLD" ]; then
        VERSION_CHECK=$((VERSION_CHECK + 1))
        continue
    fi
    
    # Ensure version changed or action was rebuilt
    if [ "$OLD" = "$NEW" ]; then
        echo -e "${YELLOW}WARN${NC} - Version not incremented in $manifest"
    else
        VERSION_CHECK=$((VERSION_CHECK + 1))
    fi
done

if [ $VERSION_CHECK -gt 0 ] || [ $MANIFEST_COUNT -eq 0 ]; then
    echo -e "${GREEN}PASS${NC}"
    CHECKS_PASSED=$((CHECKS_PASSED + 1))
fi

# Check 5: Verify GSM/VAULT credentials only in .action-secrets.env
echo -n "Verifying credentials are not in action files... "
CRED_CHECK=0

for action_file in $(git diff --cached --name-only | grep -E "\.github/actions/.*/"); do
    # Should NOT contain plaintext GSM/VAULT keys
    if git show :"$action_file" 2>/dev/null | grep -iE "VAULT_TOKEN|GSM_KEY|KMS_KEY" > /dev/null; then
        echo -e "${RED}FAIL${NC}"
        echo "❌ Credentials found in action file: $action_file"
        CHECKS_FAILED=$((CHECKS_FAILED + 1))
        FAILED=1
    else
        CRED_CHECK=$((CRED_CHECK + 1))
    fi
done

if [ $CRED_CHECK -gt 0 ] || [ $(git diff --cached --name-only | grep -E "\.github/actions/.*/" | wc -l) -eq 0 ]; then
    echo -e "${GREEN}PASS${NC}"
    CHECKS_PASSED=$((CHECKS_PASSED + 1))
fi

# Check 6: Audit log integrity
echo -n "Verifying audit log immutability... "
if git diff --cached -- .github/.immutable-audit.log | grep "^-" > /dev/null 2>&1; then
    echo -e "${RED}FAIL${NC}"
    echo "❌ Audit log modification detected (append-only violation)"
    CHECKS_FAILED=$((CHECKS_FAILED + 1))
    FAILED=1
else
    echo -e "${GREEN}PASS${NC}"
    CHECKS_PASSED=$((CHECKS_PASSED + 1))
fi

# Summary
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "✅ Checks Passed: $CHECKS_PASSED"
echo "❌ Checks Failed: $CHECKS_FAILED"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

if [ $FAILED -eq 1 ]; then
    echo ""
    echo "❌ PRE-COMMIT VALIDATION FAILED"
    echo "   • Use rebuild cycle for action changes (don't edit directly)"
    echo "   • Use GSM/VAULT/KMS for all credentials"
    echo "   • Ensure manifests have correct schema"
    echo "   • Don't modify audit logs"
    exit 1
fi

echo "✅ ALL PRE-COMMIT CHECKS PASSED"
exit 0
