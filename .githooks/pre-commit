#!/usr/bin/env bash
# Pre-commit hook: run repository secrets scanner
set -euo pipefail
HOOK_DIR=$(cd "$(dirname "$0")" && pwd)
REPO_ROOT=$(git rev-parse --show-toplevel)
echo "[pre-commit] running secrets scanner..."
bash "$REPO_ROOT/security/enhanced-secrets-scanner.sh" pre-commit
status=$?
if [[ $status -ne 0 ]]; then
  echo "[pre-commit] secrets scanner failed. Commit aborted." >&2
  exit $status
fi
echo "[pre-commit] secrets scanner passed."
exit 0
#!/usr/bin/env bash
################################################################################
# PRE-COMMIT HOOK: Multi-Pattern Credential Detection & Blocking
# 
# Prevents accidental commits of:
# • AWS Access Keys (AKIA*, secret access keys)
# • GitHub Personal Access Tokens (ghp_*)
# • Private keys (RSA, OpenSSH, EC, PKCS8)
# • API keys (Stripe, Vault, generic)
# • Cloud service account credentials (GCP, Azure)
# • Database passwords & connection strings
#
# Status: IMMUTABLE, IDEMPOTENT, AUDIT-LOGGED
# Install: ln -s ../../.githooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
#
################################################################################

set -euo pipefail

# Color codes
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

REPO_ROOT=$(git rev-parse --show-toplevel)
AUDIT_LOG="${REPO_ROOT}/.githooks/audit/pre-commit-$(date +%Y%m%d).jsonl"
mkdir -p "$(dirname "$AUDIT_LOG")"

# Enhanced credential patterns
CREDENTIAL_PATTERNS=(
    "AKIA[0-9A-Z]{16}"                          # AWS Access Key ID
    "aws_secret_access_key.*[A-Za-z0-9+/]{40}" # AWS Secret Key
    "ghp_[A-Za-z0-9_]{36,}"                     # GitHub Classic PAT
    "github_pat_[A-Za-z0-9_]{60,}"              # GitHub Fine-grained PAT
    "-----BEGIN (RSA |OPENSSH |EC |)PRIVATE"    # Private key blocks
    "-----BEGIN ENCRYPTED PRIVATE"               # Encrypted private keys
    "-----BEGIN CERTIFICATE"                     # SSL certificates (should be in dedicated dir)
    "private_key.*:.*[A-Za-z0-9+/]{20,}"        # JSON private_key fields
    "api.?key.*[=:]\s*[A-Za-z0-9_-]{32,}"       # Generic API keys
    "token.*[=:]\s*[A-Za-z0-9._-]{32,}"         # Generic tokens
    "secret.*[=:]\s*[A-Za-z0-9._-]{32,}"        # Generic secrets
    "sk_live_[a-zA-Z0-9]{32,}"                  # Stripe live key
    "pk_live_[a-zA-Z0-9]{32,}"                  # Stripe public key
    "rk_live_[a-zA-Z0-9]{32,}"                  # Stripe restricted key
    "vault.*token.*[A-Za-z0-9._-]{32,}"         # Vault tokens
    "Bearer [A-Za-z0-9_-]{32,}"                 # Bearer tokens
)

# Denied filenames (should never be committed)
DENIED_FILENAMES=(
    "\.env\.local"
    "\.env\.prod"
    "\.env\.production"
    "\.env\.staging"
    "secret"
    "credentials"
    "private.*key"
    "terraform\.tfvars"
    "\.aws.*credentials"
    "\.ssh.*id_"
    "service.?account.*\.json"
    "\.kube.*config"
)

# Get staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || echo "")

if [[ -z "$STAGED_FILES" ]]; then
    exit 0
fi

FOUND_ISSUES=0

# Check denied filenames
for pattern in "${DENIED_FILENAMES[@]}"; do
    if echo "$STAGED_FILES" | grep -iE "$pattern" >/dev/null 2>&1; then
        echo "$STAGED_FILES" | grep -iE "$pattern" | while read file; do
            echo -e "${RED}✗ BLOCKED: Dangerous filename: $file${NC}"
            echo "{\"ts\":\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\",\"result\":\"blocked\",\"file\":\"$file\",\"reason\":\"denied_filename\"}" >> "$AUDIT_LOG"
            FOUND_ISSUES=$((FOUND_ISSUES + 1))
        done
    fi
done

# Scan file contents
for file in $STAGED_FILES; do
    # Skip binary files
    if file "$file" 2>/dev/null | grep -q "binary"; then
        continue
    fi
    
    # Skip directories with known binaries
    if [[ "$file" == *".terraform"* ]] || [[ "$file" == *".venv"* ]] || [[ "$file" == *"node_modules"* ]]; then
        continue
    fi
    
    # Check staged content for credential patterns
    for pattern in "${CREDENTIAL_PATTERNS[@]}"; do
        if git show ":$file" 2>/dev/null | grep -iE "$pattern" >/dev/null 2>&1; then
            # Allow Terraform resource references (not actual credentials)
            MATCH=$(git show ":$file" 2>/dev/null | grep -iE "$pattern" || true)
            if echo "$MATCH" | grep -qE '(random_password|google_secret_manager|var\.|module\.|data\.|local\.)'; then
                continue
            fi
            echo -e "${RED}✗ BLOCKED: Credential pattern detected in $file${NC}"
            echo "  Pattern: $pattern"
            echo "{\"ts\":\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\",\"result\":\"blocked\",\"file\":\"$file\",\"pattern\":\"$pattern\"}" >> "$AUDIT_LOG"
            FOUND_ISSUES=$((FOUND_ISSUES + 1))
        fi
    done
done

if [ $FOUND_ISSUES -gt 0 ]; then
    echo ""
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${RED}⚠️  COMMIT BLOCKED: $FOUND_ISSUES credential(s) detected${NC}"
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo "Actions:"
    echo "  1. Remove: git reset <file> && vim <file>"
    echo "  2. Store securely: gcloud secrets create <name> --data-file=<(new_value)"
    echo "  3. Add to .gitignore"
    echo "  4. Verify audit: $AUDIT_LOG"
    echo ""
    echo "{\"ts\":\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\",\"result\":\"rejected\",\"issues\":$FOUND_ISSUES}" >> "$AUDIT_LOG"
    exit 1
fi

echo -e "${GREEN}✓ Pre-commit verification passed: No credentials detected${NC}"
echo "{\"ts\":\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\",\"result\":\"approved\"}" >> "$AUDIT_LOG"
exit 0
