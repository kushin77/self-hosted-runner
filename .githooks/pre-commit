#!/bin/bash
################################################################################
# PRE-COMMIT HOOK: Prevent Credential Commits
#
# This hook prevents accidental commits of:
# - SSH private keys (-----BEGIN, -----END, ssh-rsa, etc.)
$PLACEHOLDER
# - GCP credentials (service_account, private_key, etc.)
# - Encryption keys (PRIVATE, SECRET, api_key, etc.)
#
# Install: cp .githooks/pre-commit .git/hooks/pre-commit && chmod 755 .git/hooks/pre-commit
#
################################################################################

set -euo pipefail

# Color codes
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

# Credential patterns to detect
CREDENTIAL_PATTERNS=(
    "-----BEGIN.*PRIVATE"           # SSH/OpenSSL private keys
    "-----BEGIN RSA"                # RSA keys
    "ssh-rsa\|ssh-ed25519"         # SSH public keys (should not be in private repos)
    "AKIA[0-9A-Z]\{16\}"           # AWS access key ID
$PLACEHOLDER
    "private_key.:..*-----BEGIN"   # GCP service account
$PLACEHOLDER
    "app_password"                  # Application password
$PLACEHOLDER
    "api_key.:..*[a-zA-Z0-9]{32}" # Generic API key
    "token.:..*[a-zA-Z0-9]{32}"    # Generic token
$PLACEHOLDER
)

# Get staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [[ -z "$STAGED_FILES" ]]; then
    exit 0
fi

# Check for credential patterns
FOUND_CREDENTIALS=false

for file in $STAGED_FILES; do
    # Skip binary files and known safe patterns
    if [[ "$file" == *.bin ]] || [[ "$file" == *.jpg ]] || [[ "$file" == *.png ]]; then
        continue
    fi
    
    # Check staged content for credential patterns
    for pattern in "${CREDENTIAL_PATTERNS[@]}"; do
        if git show ":$file" 2>/dev/null | grep -iE "$pattern" > /dev/null 2>&1; then
            if [[ "$FOUND_CREDENTIALS" == false ]]; then
                echo ""
                echo -e "${RED}❌ ERROR: Detected potential credentials in staged files${NC}"
                echo ""
                FOUND_CREDENTIALS=true
            fi
            
            echo -e "${YELLOW}File:${NC} $file"
            echo -e "${YELLOW}Pattern:${NC} $pattern"
            echo -e "${YELLOW}Action:${NC} Remove from git and add to .gitignore"
            echo ""
        fi
    done
done

if [[ "$FOUND_CREDENTIALS" == true ]]; then
    echo -e "${RED}Commit blocked to prevent accidental credential exposure.${NC}"
    echo ""
    echo "To fix:"
    echo "  1. Remove credential from file: vim $file"
    echo "  2. Unstage file: git reset $file"
    echo "  3. Add to .gitignore: echo $file >> .gitignore"
    echo "  4. Commit: git commit ..."
    echo ""
    echo "For SSH keys, use credential manager instead:"
    echo "  - Vault: bash scripts/provision-operator-credentials.sh vault"
    echo "  - AWS: bash scripts/provision-operator-credentials.sh aws"
    echo "  - GSM: bash scripts/provision-operator-credentials.sh gsm"
    echo ""
    exit 1
fi

exit 0
