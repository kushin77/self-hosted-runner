#!/bin/bash
# Performance Benchmarking Suite
# Measures throughput, latency, and resource utilization
# Usage: bash tests/performance/run-performance-benchmarks.sh

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
BENCHMARK_DIR="/tmp/provisioner-benchmarks-$TIMESTAMP"
RESULTS_FILE="$BENCHMARK_DIR/benchmark-results.json"

# Color output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

echo "╔════════════════════════════════════════════════════════════╗"
echo "║  Performance Benchmarking Suite                            ║"
echo "║  Results: $BENCHMARK_DIR                                   ║"
echo "╚════════════════════════════════════════════════════════════╝"
echo ""

mkdir -p "$BENCHMARK_DIR"

# Initialize results JSON
echo "{}" > "$RESULTS_FILE"

# Helper function to record benchmark result
function record_result() {
  local category=$1
  local test_name=$2
  local value=$3
  local unit=$4
  
  cat > /tmp/update_json_$$.sh << EOF
const fs = require('fs');
const data = JSON.parse(fs.readFileSync('$RESULTS_FILE', 'utf8'));
if (!data['$category']) data['$category'] = {};
data['$category']['$test_name'] = { value: $value, unit: '$unit' };
fs.writeFileSync('$RESULTS_FILE', JSON.stringify(data, null, 2));
EOF
  node /tmp/update_json_$$.sh
  rm /tmp/update_json_$$.sh
}

# ============= SECTION 1: Job Throughput Benchmarks =============
echo -e "${BLUE}[1. Job Processing Throughput]${NC}"

# Benchmark: Jobs enqueued per second
echo -n "  Measuring job queue throughput (1000 jobs) ... "
QUEUE_FILE="$BENCHMARK_DIR/queue-throughput.json"
START_TIME=$(date +%s%N)

for i in {1..1000}; do
  echo "{\"job_id\": \"bench-job-$i\", \"timestamp\": \"$(date -Iseconds)\", \"status\": \"queued\"}" >> "$QUEUE_FILE"
done

END_TIME=$(date +%s%N)
ELAPSED_MS=$(( (END_TIME - START_TIME) / 1000000 ))
JOBS_PER_SEC=$(echo "scale=2; 1000 * 1000 / $ELAPSED_MS" | bc)

echo -e "${GREEN}$JOBS_PER_SEC jobs/sec${NC}"
record_result "throughput" "jobs_enqueued_per_sec" "$JOBS_PER_SEC" "jobs/sec"

# Benchmark: Jobs processed per second
echo -n "  Processing job throughput (1000 jobs) ... "
START_TIME=$(date +%s%N)

for i in {1..1000}; do
  sed -i "s/queued/processing/" "$QUEUE_FILE" 2>/dev/null || true
  sed -i "s/processing/completed/" "$QUEUE_FILE" 2>/dev/null || true
done

END_TIME=$(date +%s%N)
ELAPSED_MS=$(( (END_TIME - START_TIME) / 1000000 ))
JOBS_COMPLETED_PER_SEC=$(echo "scale=2; 1000 * 1000 / $ELAPSED_MS" | bc)

echo -e "${GREEN}$JOBS_COMPLETED_PER_SEC jobs/sec${NC}"
record_result "throughput" "jobs_completed_per_sec" "$JOBS_COMPLETED_PER_SEC" "jobs/sec"

# ============= SECTION 2: Latency Benchmarks =============
echo ""
echo -e "${BLUE}[2. Operation Latency]${NC}"

# Benchmark: Job enqueue latency
echo -n "  Job enqueue operation (mean of 100) ... "
LATENCIES=()
for i in {1..100}; do
  START=$(date +%s%N)
  echo "{\"job_id\": \"latency-test-$i\"}" >> /tmp/latency_test.json 2>/dev/null || true
  END=$(date +%s%N)
  LATENCY=$(( (END - START) / 1000 ))  # Convert to microseconds
  LATENCIES+=($LATENCY)
done

# Calculate mean
MEAN=0
for lat in "${LATENCIES[@]}"; do
  MEAN=$((MEAN + lat))
done
MEAN=$((MEAN / 100))

echo -e "${GREEN}${MEAN}µs${NC}"
record_result "latency" "job_enqueue_mean_us" "$MEAN" "microseconds"

# Benchmark: Terraform workspace creation
echo -n "  Terraform workspace creation (mean of 10) ... "
LATENCIES=()
for i in {1..10}; do
  WORKSPACE="$BENCHMARK_DIR/tf-workspace-$i"
  START=$(date +%s%N)
  mkdir -p "$WORKSPACE"
  cat > "$WORKSPACE/main.tf" << 'EOF'
terraform {
  required_version = ">= 1.0"
}

provider "github" {
  version = "~> 6.0"
}

resource "null_resource" "benchmark" {
  triggers = {
    id = "bench-$i"
  }
}
EOF
  END=$(date +%s%N)
  LATENCY=$(( (END - START) / 1000000 ))  # Convert to milliseconds
  LATENCIES+=($LATENCY)
done

# Calculate mean
MEAN=0
for lat in "${LATENCIES[@]}"; do
  MEAN=$((MEAN + lat))
done
MEAN=$((MEAN / 10))

echo -e "${GREEN}${MEAN}ms${NC}"
record_result "latency" "terraform_workspace_creation_ms" "$MEAN" "milliseconds"

# ============= SECTION 3: Resource Utilization =============
echo ""
echo -e "${BLUE}[3. Resource Utilization]${NC}"

# Get current CPU and memory baseline
echo -n "  CPU usage baseline ... "
CPU_USAGE=$(ps aux | awk 'NR>1 { sum += $3 } END { print sum }' 2>/dev/null || echo "1.0")
echo -e "${GREEN}$CPU_USAGE%${NC}"
record_result "resources" "cpu_baseline_percent" "$CPU_USAGE" "percent"

echo -n "  Memory usage baseline ... "
MEM_USAGE=$(free | awk 'NR==2 { printf("%.1f", $3/$2 * 100.0) }')
echo -e "${GREEN}$MEM_USAGE%${NC}"
record_result "resources" "memory_baseline_percent" "$MEM_USAGE" "percent"

# Disk I/O performance
echo -n "  Disk write performance (100MB file) ... "
TEMP_FILE="$BENCHMARK_DIR/disk-io-test.bin"
START=$(date +%s%N)
dd if=/dev/zero of="$TEMP_FILE" bs=1M count=100 2>/dev/null || true
END=$(date +%s%N)
ELAPSED_MS=$(( (END - START) / 1000000 ))
WRITE_SPEED_MBS=$(echo "scale=2; 100 * 1000 / $ELAPSED_MS" | bc)
echo -e "${GREEN}$WRITE_SPEED_MBS MB/s${NC}"
record_result "resources" "disk_write_speed_mbs" "$WRITE_SPEED_MBS" "MB/s"

# Docker performance
echo -n "  Docker image pull time (alpine) ... "
START=$(date +%s%N)
docker pull alpine:latest > /dev/null 2>&1 || echo "Docker pull skipped (may be cached)"
END=$(date +%s%N)
ELAPSED_MS=$(( (END - START) / 1000000 ))
if [[ $ELAPSED_MS -gt 100 ]]; then
  echo -e "${GREEN}${ELAPSED_MS}ms${NC}"
  record_result "resources" "docker_pull_time_ms" "$ELAPSED_MS" "milliseconds"
else
  echo -e "${YELLOW}(cached)${NC}"
fi

# ============= SECTION 4: Vault Operation Performance =============
echo ""
echo -e "${BLUE}[4. Vault Operations Performance]${NC}"

# Check if Vault is running
if nc -z 127.0.0.1 8200 2>/dev/null || vault status > /dev/null 2>&1; then
  VAULT_TOKEN="${VAULT_TOKEN:-$(cat ~/.vault-token 2>/dev/null || echo '')}"
  
  if [[ -n "$VAULT_TOKEN" ]]; then
    export VAULT_ADDR="${VAULT_ADDR:-http://127.0.0.1:8200}"
<REDACTED_SECRET_REMOVED_BY_AUTOMATION>
    
    # Vault auth latency
    echo -n "  Vault token lookup (mean of 10) ... "
    LATENCIES=()
    for i in {1..10}; do
      START=$(date +%s%N)
      vault token lookup > /dev/null 2>&1 || true
      END=$(date +%s%N)
      LATENCY=$(( (END - START) / 1000 ))
      LATENCIES+=($LATENCY)
    done
    
    MEAN=0
    for lat in "${LATENCIES[@]}"; do
      MEAN=$((MEAN + lat))
    done
    MEAN=$((MEAN / 10))
    
    echo -e "${GREEN}${MEAN}µs${NC}"
    record_result "vault" "token_lookup_mean_us" "$MEAN" "microseconds"
    
    # Vault secret read latency
    echo -n "  Vault secret read latency (mean of 10) ... "
    LATENCIES=()
    for i in {1..10}; do
      START=$(date +%s%N)
      vault kv get -field=username kv/provisioner-worker/test-secret 2>/dev/null || true
      END=$(date +%s%N)
      LATENCY=$(( (END - START) / 1000 ))
      LATENCIES+=($LATENCY)
    done
    
    MEAN=0
    for lat in "${LATENCIES[@]}"; do
      MEAN=$((MEAN + lat))
    done
    MEAN=$((MEAN / 10))
    
    echo -e "${GREEN}${MEAN}µs${NC}"
    record_result "vault" "secret_read_mean_us" "$MEAN" "microseconds"
  else
    echo "  ⊘ VAULT_TOKEN not set, skipping Vault benchmarks"
  fi
else
  echo "  ⊘ Vault not running, skipping Vault benchmarks"
fi

# ============= SECTION 5: Script Performance =============
echo ""
echo -e "${BLUE}[5. Script Execution Performance]${NC}"

# Measure smoke test execution time
echo -n "  Smoke test suite execution time ... "
START=$(date +%s%N)
timeout 30 bash tests/smoke/run-smoke-tests.sh > /dev/null 2>&1 || true
END=$(date +%s%N)
ELAPSED_S=$(echo "scale=2; ($(date +%s%N | awk '{print($1 - '$(date +%s%N | awk '{print $1}')'}')) / 1000000000" | bc || echo "30")
ELAPSED_MS=$(( (END - START) / 1000000 ))
ELAPSED_S=$(echo "scale=2; $ELAPSED_MS / 1000" | bc)

echo -e "${GREEN}${ELAPSED_S}s${NC}"
record_result "scripts" "smoke_test_time_seconds" "$ELAPSED_S" "seconds"

# ============= RESULTS SUMMARY =============
echo ""
echo "════════════════════════════════════════════════════════════"
echo -e "${BLUE}Performance Benchmark Results${NC}"
echo "════════════════════════════════════════════════════════════"
echo ""

# Display results from JSON
if command -v jq &> /dev/null; then
  jq '.' "$RESULTS_FILE" 2>/dev/null || cat "$RESULTS_FILE"
else
  cat "$RESULTS_FILE"
fi

echo ""
echo "════════════════════════════════════════════════════════════"
echo -e "${GREEN}✓ Benchmark Results Summary${NC}"
echo "Results file: $RESULTS_FILE"
echo "Benchmark artifacts: $BENCHMARK_DIR"
echo ""
echo "Key Metrics Captured:"
echo "  ✓ Job throughput (enqueue, processing)"
echo "  ✓ Operation latency (mean times)"
echo "  ✓ Resource utilization (CPU, memory, disk I/O)"
echo "  ✓ Docker performance"
echo "  ✓ Vault operation performance"
echo "  ✓ Script execution times"
echo ""
echo "Next Steps:"
echo "  1. Review results in: $RESULTS_FILE"
echo "  2. Establish performance baselines"
echo "  3. Compare across commits for regression detection"
echo "  4. Use for optimization targeting"
echo "════════════════════════════════════════════════════════════"
