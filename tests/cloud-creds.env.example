# Copy this file to cloud-creds.env and fill in secrets before running cloud tests.
# DO NOT commit the actual `cloud-creds.env` to source control.
# Example placeholders — replace values with real credentials OR use CI/web-portal secrets.

# ===== AWS =====
# AWS region to run EC2 tests in
AWS_REGION=us-east-1
# Optional: export AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY via CI/web portal
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...

# ===== GCP =====
# GCP project and optional zone/region
GCP_PROJECT=my-project
GCP_ZONE=us-central1-a
GCP_REGION=us-central1
# For GCP you can either set GOOGLE_APPLICATION_CREDENTIALS pointing to a mounted
# service account JSON file, or set the key JSON content via a CI secret and write
# it to a file inside the runner environment before sourcing this file.
# GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp-sa.json

# ===== Azure =====
AZURE_SUBSCRIPTION=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# For non-interactive Azure auth set these (Service Principal)
# AZURE_CLIENT_ID=...
# AZURE_CLIENT_SECRET=...
# AZURE_TENANT_ID=...

# ===== GitHub =====
# Token used to register ephemeral self-hosted runners
GITHUB_TOKEN=ghr_xxx

# ===== Notes =====
# 1) After creating `cloud-creds.env` make it readable only by the owner: `chmod 600 tests/cloud-creds.env`
# 2) The master runner will auto-load `tests/cloud-creds.env` when present.
# 3) Never commit `cloud-creds.env` to the repo. Add it to .gitignore if you create it locally.
