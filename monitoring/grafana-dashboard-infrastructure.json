{
  "dashboard": {
    "title": "Infrastructure & Node Metrics",
    "description": "Real-time infrastructure health monitoring for runner workers",
    "tags": ["infrastructure", "node-metrics", "worker-health"],
    "timezone": "browser",
    "panels": [
      {
        "title": "Node Status",
        "targets": [
          {
            "expr": "up{job=\"runner-worker\"}",
            "legendFormat": "{{ instance }} Status"
          }
        ],
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 }
      },
      {
        "title": "CPU Usage (%)",
        "targets": [
          {
            "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
            "legendFormat": "{{ instance }}"
          }
        ],
        "type": "timeseries",
        "fieldConfig": { "defaults": { "unit": "percent" } },
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 }
      },
      {
        "title": "Memory Usage (%)",
        "targets": [
          {
            "expr": "((node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes) * 100",
            "legendFormat": "{{ instance }}"
          }
        ],
        "type": "timeseries",
        "fieldConfig": { "defaults": { "unit": "percent" } },
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 }
      },
      {
        "title": "Disk Usage (%)",
        "targets": [
          {
            "expr": "(node_filesystem_size_bytes{fstype!=\"tmpfs\",fstype!=\"fuse.lxcfs\"} - node_filesystem_avail_bytes{fstype!=\"tmpfs\",fstype!=\"fuse.lxcfs\"}) / node_filesystem_size_bytes{fstype!=\"tmpfs\",fstype!=\"fuse.lxcfs\"} * 100",
            "legendFormat": "{{ instance }} ({{ device_name }})"
          }
        ],
        "type": "timeseries",
        "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 80 }, { "color": "red", "value": 90 }] } } },
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 }
      },
      {
        "title": "Network I/O (bytes/sec)",
        "targets": [
          {
            "expr": "rate(node_network_receive_bytes_total[5m]) + rate(node_network_transmit_bytes_total[5m])",
            "legendFormat": "{{ instance }} - {{ device }}"
          }
        ],
        "type": "timeseries",
        "fieldConfig": { "defaults": { "unit": "Bps" } },
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 }
      },
      {
        "title": "Load Average",
        "targets": [
          {
            "expr": "node_load1",
            "legendFormat": "{{ instance }} (1m)"
          },
          {
            "expr": "node_load5",
            "legendFormat": "{{ instance }} (5m)"
          },
          {
            "expr": "node_load15",
            "legendFormat": "{{ instance }} (15m)"
          }
        ],
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 }
      },
      {
        "title": "System Services Status",
        "targets": [
          {
            "expr": "node_systemd_unit_state{state=\"active\"}",
            "legendFormat": "{{ name }} - {{ state }}"
          }
        ],
        "type": "table",
        "gridPos": { "h": 10, "w": 12, "x": 12, "y": 20 }
      },
      {
        "title": "Process Count",
        "targets": [
          {
            "expr": "node_procs_running",
            "legendFormat": "Running ({{ instance }})"
          },
          {
            "expr": "node_procs_blocked",
            "legendFormat": "Blocked ({{ instance }})"
          }
        ],
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 }
      },
      {
        "title": "Filesystem I/O Operations (ops/sec)",
        "targets": [
          {
            "expr": "rate(node_disk_reads_completed_total[5m]) + rate(node_disk_writes_completed_total[5m])",
            "legendFormat": "{{ instance }} - {{ device }}"
          }
        ],
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 }
      }
    ],
    "schemaVersion": 38,
    "version": 1
  }
}
