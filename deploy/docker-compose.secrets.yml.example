version: '3.8'
services:
  canonical-secrets-api:
    build:
      context: .
      dockerfile: backend/Dockerfile
    image: <DOCKER_REGISTRY>/canonical-secrets-api:<IMAGE_TAG>
    environment:
      - PORT=8000
      - ENVIRONMENT=staging
      - NO_GITHUB_ACTIONS=1
    ports:
      - "8000:8000"
    restart: unless-stopped

  portal:
    image: <DOCKER_REGISTRY>/secrets-portal:<PORTAL_IMAGE_TAG>
    ports:
      - "3000:3000"
    restart: unless-stopped

networks:
  default:
    driver: bridge

# NOTE: keep sensitive values out of this file. Use environment variables or an
# /etc/canonical_secrets.env file on the host for runtime secrets.