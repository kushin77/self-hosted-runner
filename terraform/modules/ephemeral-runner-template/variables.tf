##############################################################################
# Variables for Ephemeral Runner Instance Template Module
##############################################################################

variable "project_id" {
  type        = string
  description = "GCP Project ID"
  nullable    = false
}

variable "region" {
  type        = string
  description = "GCP Region for resources"
  default     = "us-central1"
}

variable "zone" {
  type        = string
  description = "GCP Zone for instance group"
  default     = "us-central1-a"
}

variable "environment" {
  type        = string
  description = "Environment name (staging, production, etc.)"
  validation {
    condition     = contains(["staging", "production", "development"], var.environment)
    error_message = "Environment must be staging, production, or development"
  }
}

variable "image_digest" {
  type        = string
  description = "Immutable image digest (e.g., sha256:abc123...)"
  validation {
    condition     = startswith(var.image_digest, "sha256:")
    error_message = "Image digest must start with 'sha256:'"
  }
}

variable "image_digest_short" {
  type        = string
  description = "Short image digest for labeling (e.g., abc123)"
  default     = ""
}

variable "machine_type" {
  type        = string
  description = "GCE machine type"
  default     = "e2-medium"
  validation {
    condition     = can(regex("^e2-|n2-|t2d-|c3-", var.machine_type))
    error_message = "Machine type must be from e2, n2, t2d, or c3 family"
  }
}

variable "boot_disk_size" {
  type        = number
  description = "Boot disk size in GB (auto-deleted on termination)"
  default     = 50
  validation {
    condition     = var.boot_disk_size >= 20 && var.boot_disk_size <= 1000
    error_message = "Boot disk size must be between 20 and 1000 GB"
  }
}

variable "disk_encryption_key" {
  type        = string
  sensitive   = true
  description = "32-byte base64-encoded encryption key for disks"
  default     = "ácACACACACA"
}

variable "network_id" {
  type        = string
  description = "VPC network ID for instances"
  nullable    = false
}

variable "subnetwork_id" {
  type        = string
  description = "VPC subnetwork ID for instances"
  nullable    = false
}

variable "provisioner_api_endpoint" {
  type        = string
  description = "Provisioner API endpoint (for runner token retrieval)"
  default     = "https://provisioner.internal"
}

variable "github_repository_url" {
  type        = string
  description = "GitHub repository URL (if not using provisioner API)"
  default     = ""
}

variable "min_replicas" {
  type        = number
  description = "Minimum number of pre-warmed instances"
  default     = 10
  validation {
    condition     = var.min_replicas >= 1 && var.min_replicas <= 50
    error_message = "Min replicas must be between 1 and 50"
  }
}

variable "max_replicas" {
  type        = number
  description = "Maximum instances for auto-scaling"
  default     = 200
  validation {
    condition     = var.max_replicas > var.min_replicas && var.max_replicas <= 1000
    error_message = "Max replicas must be greater than min and not exceed 1000"
  }
}

variable "idle_timeout_seconds" {
  type        = number
  description = "Seconds of idle before instance self-destructs"
  default     = 900 # 15 minutes
  validation {
    condition     = var.idle_timeout_seconds >= 60 && var.idle_timeout_seconds <= 3600
    error_message = "Idle timeout must be between 60 and 3600 seconds"
  }
}

variable "max_lifetime_seconds" {
  type        = number
  description = "Maximum instance lifetime before forced termination"
  default     = 3600 # 1 hour
  validation {
    condition     = var.max_lifetime_seconds >= 600 && var.max_lifetime_seconds <= 86400
    error_message = "Max lifetime must be between 600 seconds (10min) and 86400 seconds (24h)"
  }
}

variable "use_preemptible" {
  type        = bool
  description = "Use preemptible/spot instances for cost savings"
  default     = true
}

variable "cost_center" {
  type        = string
  description = "Cost center for resource tagging"
  default     = "infrastructure"
}

variable "team_label" {
  type        = string
  description = "Team label for resource tagging"
  default     = "platform"
}

variable "additional_labels" {
  type        = map(string)
  description = "Additional labels for instances"
  default     = {}
}

variable "startup_script_content" {
  type        = string
  sensitive   = true
  description = "Startup script content (will be used instead of file if provided)"
  default     = ""
}

variable "shutdown_script_content" {
  type        = string
  sensitive   = true
  description = "Shutdown script content (will be used instead of file if provided)"
  default     = ""
}
