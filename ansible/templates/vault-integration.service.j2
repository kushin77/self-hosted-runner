[Unit]
Description=Vault Integration rotation daemon
After=network.target

[Service]
Type=simple
User=root
Group=root
WorkingDirectory={{ install_dir | default('/opt/runner/integrations') }}
ExecStart={{ install_dir | default('/opt/runner/integrations') }}/vault-integration.sh daemon {{ install_dir | default('/opt/runner/integrations') }}/vault-rotation.yaml
Restart=on-failure
RestartSec=30
LimitNOFILE=65536
ProtectSystem=full
PrivateTmp=true
Environment=VAULT_ADDR={{ vault_addr | default('https://vault.internal:8200') }}

[Install]
WantedBy=multi-user.target
