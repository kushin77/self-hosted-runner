[Unit]
Description=Vault Agent (auto-auth + templating)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=deploy
Group=deploy
ExecStart=/usr/local/bin/vault agent -config=/etc/vault/agent.hcl
Restart=on-failure
RestartSec=10
Environment=VAULT_ADDR=${VAULT_ADDR:-}

[Install]
WantedBy=multi-user.target
