name: Ops Issue Completion Automation

on:
  # Converted to event-driven: removed frequent polling
  workflow_dispatch:
  repository_dispatch:
    types: [ops-issue-check, ops-issue-trigger]

permissions:
  contents: read
  issues: write
  actions: write

concurrency:
  group: ops-issue-completion
  cancel-in-progress: false

permissions:
  contents: read
  issues: write
  pull-requests: read

jobs:
  check-completion:
    runs-on: ubuntu-latest
    name: Auto-detect & close completed issues
    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          fetch-depth: 1

      - name: Configure Git
        run: |
          git config --global user.name "Automation Bot"
          git config --global user.email "automation@github.actions"

      - name: Verify gh CLI
        run: gh --version

      - name: Run ops issue completion automation
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          chmod +x scripts/automation/ops-issue-completion.sh
          bash scripts/automation/ops-issue-completion.sh

      - name: Post completion report (if issues closed)
        if: always()
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          cat << 'EOF' > /tmp/ops_completion_report.md
          ## Ops Automation Report
          
          **Timestamp:** $(date -Iseconds)
          **Workflow:** Ops Issue Completion
          **Status:** ✅ Complete
          **Duration:** ${{ job.duration }}s
          
          **Automation Actions:**
          - Auto-detection: Issue completion conditions
          - Auto-closure: Resolved issues
          - Auto-triggers: Next-phase workflows
          - Status tracking: Phase 1-2 progress
          
          **System Properties:**
          - Immutable: All in Git
          - Ephemeral: State resets each run
          - Idempotent: Safe to re-execute
          - No-Ops: Fully scheduled automation
          - Hands-Off: Operator just adds secrets
          
          **Next Run:** In 5 minutes
          EOF
          
          # Post to #1 (master tracking)
          gh issue comment 1 --repo kushin77/self-hosted-runner \
            --body "$(cat /tmp/ops_completion_report.md)" 2>/dev/null || true
