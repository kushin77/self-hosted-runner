name: Fetch Secrets from GCP Secret Manager

on:
  workflow_dispatch:
    inputs:
      gcp_project_id:
        description: 'GCP Project ID'
        required: true
        default: 'gcp-eiq'
      secret_names:
        description: 'Comma-separated secret names to fetch from GSM (e.g., aws-access-key,aws-secret-key,aws-oidc-role-arn)'
        required: true
        default: 'aws-access-key-id,aws-secret-access-key,aws-oidc-role-arn'

permissions:
  contents: read
  actions: write
  id-token: write

jobs:
  fetch-gsm-secrets:
    runs-on: ubuntu-latest
    outputs:
      secrets_fetched: ${{ steps.fetch.outputs.success }}
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Authenticate to Google Cloud
        uses: google-github-actions/auth@v2
        with:
          workload_identity_provider: ${{ secrets.GCP_WORKLOAD_IDENTITY_PROVIDER }}
          service_account: ${{ secrets.GCP_SERVICE_ACCOUNT }}

      - name: Set up Cloud SDK
        uses: google-github-actions/setup-gcloud@v2

      - name: Fetch secrets from GSM and set repo secrets
        id: fetch
        env:
          GCP_PROJECT_ID: ${{ github.event.inputs.gcp_project_id }}
          SECRET_NAMES: ${{ github.event.inputs.secret_names }}
        run: |
          set -euo pipefail
          
          # Enable Secret Manager API
          gcloud services enable secretmanager.googleapis.com --project="$GCP_PROJECT_ID" || true
          
          # Parse secret names and fetch each
          IFS=',' read -ra SECRETS <<< "$SECRET_NAMES"
          for secret_name in "${SECRETS[@]}"; do
            secret_name=$(echo "$secret_name" | xargs)  # trim whitespace
            echo "Fetching secret: $secret_name"
            
            secret_value=$(gcloud secrets versions access latest --secret="$secret_name" --project="$GCP_PROJECT_ID") || continue
            
            # Convert secret name to repo secret name (uppercase, replace hyphens with underscores)
            repo_secret_name=$(echo "$secret_name" | tr '[:lower:]' '[:upper:]' | tr '-' '_')
            
            # Store in temporary file (never print to logs)
            echo "${repo_secret_name}=${secret_value}" >> /tmp/gsm_secrets.env
            echo "✓ Fetched ${repo_secret_name}"
          done
          
          echo "success=true" >> $GITHUB_OUTPUT

      - name: Set repository secrets
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          set -euo pipefail
          
          if [ ! -f /tmp/gsm_secrets.env ]; then
            echo "No secrets fetched"
            exit 0
          fi
          
          while IFS='=' read -r key value; do
            if [ -z "$key" ] || [ -z "$value" ]; then
              continue
            fi
            
            echo "Setting repo secret: $key"
            gh secret set "$key" --body "$value" --repo "${{ github.repository }}" || true
          done < /tmp/gsm_secrets.env
          
          rm -f /tmp/gsm_secrets.env
          echo "✓ All secrets synced to repository"

      - name: Notify completion
        run: |
          echo "Secrets fetched and synced from GCP Secret Manager"
          echo "Repository: ${{ github.repository }}"
          echo "GCP Project: ${{ github.event.inputs.gcp_project_id }}"
      - name: Close provisioning issue
        if: ${{ steps.fetch.outputs.success == 'true' }}
        run: |
          gh issue comment 1328 --body "Secrets have been synced from GSM to repository. Cloud provisioning step complete." --repo "${{ github.repository }}" || true
          gh issue close 1328 --repo "${{ github.repository }}" || true
