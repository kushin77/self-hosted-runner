name: Sync GSM Secrets to GitHub

on:
  schedule:
    - cron: '0 */6 * * *'  # Every 6 hours
  workflow_dispatch:
  repository_dispatch:
    types: [manual-secret-sync]
  workflow_call: {}

concurrency:
  group: sync-gsm-to-github-secrets-${{ github.ref }}
  cancel-in-progress: false

permissions:
  contents: read
  actions: write
  id-token: write  # Required for OIDC

jobs:
  sync-secrets:
    name: Sync Secrets from GCP Secret Manager
    runs-on: ubuntu-latest
    timeout-minutes: 10
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Load resilience helpers
        run: |
          set -euo pipefail
          source .github/scripts/resilience.sh || true

      - name: Authenticate to Google Cloud (OIDC - hands-off)
        uses: google-github-actions/auth@v2
        with:
          workload_identity_provider: ${{ secrets.GCP_WORKLOAD_IDENTITY_PROVIDER }}
          service_account_email: ${{ secrets.GCP_SERVICE_ACCOUNT_EMAIL }}
          cleanup_credentials: true
        continue-on-error: true

      - name: Set up Google Cloud SDK
        uses: google-github-actions/setup-gcloud@v2
        with:
          install_components: 'gke-gcloud-auth-plugin'
        continue-on-error: true

      - name: Check GCP availability
        id: gcp-check
        run: |
          if gcloud auth list --filter=status:ACTIVE --format="value(account)" &>/dev/null; then
            echo "gcp_available=true" >> $GITHUB_OUTPUT
            echo "✓ GCP credentials available"
          else
            echo "gcp_available=false" >> $GITHUB_OUTPUT
            echo "⚠ GCP credentials not available; secrets will not be synced"
          fi

      - name: Fetch RUNNER_MGMT_TOKEN from GSM
        if: steps.gcp-check.outputs.gcp_available == 'true'
        id: runner-token
        run: |
          set +e
          TOKEN=$(retry_command 5 10 sh -c "gcloud secrets versions access latest --secret=runner-mgmt-token --project=${{ secrets.GCP_PROJECT_ID }}" 2>/dev/null)
          if [ $? -eq 0 ] && [ -n "$TOKEN" ]; then
            echo "::add-mask::$TOKEN"
            echo "token=$TOKEN" >> $GITHUB_OUTPUT
            echo "✓ RUNNER_MGMT_TOKEN fetched from GSM"
          else
            echo "⚠ RUNNER_MGMT_TOKEN not found in GSM or not available"
          fi

      - name: Fetch DEPLOY_SSH_KEY from GSM
        if: steps.gcp-check.outputs.gcp_available == 'true'
        id: ssh-key
        run: |
          set +e
          KEY=$(retry_command 5 10 sh -c "gcloud secrets versions access latest --secret=deploy-ssh-key --project=${{ secrets.GCP_PROJECT_ID }}" 2>/dev/null)
          if [ $? -eq 0 ] && [ -n "$KEY" ]; then
            echo "::add-mask::${KEY:0:20}..."
            echo "key=$KEY" >> $GITHUB_OUTPUT
            echo "✓ DEPLOY_SSH_KEY fetched from GSM"
          else
            echo "⚠ DEPLOY_SSH_KEY not found in GSM or not available"
          fi

      - name: Install GitHub CLI
        run: |
          sudo apt-get update
          sudo apt-get install -y gh

      - name: Update RUNNER_MGMT_TOKEN in GitHub Secrets
        if: steps.runner-token.outputs.token != ''
        env:
          GH_TOKEN: ${{ github.token }}
        run: |
          TOKEN="${{ steps.runner-token.outputs.token }}"
          gh secret set RUNNER_MGMT_TOKEN --repo "${{ github.repository }}" --body "$TOKEN"
          echo "✓ RUNNER_MGMT_TOKEN synced to GitHub secrets"

      - name: Update DEPLOY_SSH_KEY in GitHub Secrets
        if: steps.ssh-key.outputs.key != ''
        env:
          GH_TOKEN: ${{ github.token }}
        run: |
          KEY="${{ steps.ssh-key.outputs.key }}"
          gh secret set DEPLOY_SSH_KEY --repo "${{ github.repository }}" --body "$KEY"
          echo "✓ DEPLOY_SSH_KEY synced to GitHub secrets"

      - name: Report sync status
        if: always()
        run: |
          echo "## Secret Sync Report" >> $GITHUB_STEP_SUMMARY
          echo "" >> $GITHUB_STEP_SUMMARY
          echo "- GCP Available: ${{ steps.gcp-check.outputs.gcp_available }}" >> $GITHUB_STEP_SUMMARY
          echo "- RUNNER_MGMT_TOKEN: ${{ steps.runner-token.outputs.token != '' && '✓ Synced' || '⚠ Not synced' }}" >> $GITHUB_STEP_SUMMARY
          echo "- DEPLOY_SSH_KEY: ${{ steps.ssh-key.outputs.key != '' && '✓ Synced' || '⚠ Not synced' }}" >> $GITHUB_STEP_SUMMARY
