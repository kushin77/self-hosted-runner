name: Observability E2E Secrets Check

on:
  workflow_dispatch:
    inputs:
      notify_issue:
        description: 'Issue number to post results to'
        required: false
        default: '1378'

permissions:
  issues: write
  contents: read

jobs:
  secret-check:
    runs-on: ubuntu-latest
    steps:
      - name: Check secrets presence
        env:
          SLACK_WEBHOOK_URL: ${{ secrets.SLACK_WEBHOOK_URL }}
          PAGERDUTY_SERVICE_KEY: ${{ secrets.PAGERDUTY_SERVICE_KEY }}
          PAGERDUTY_API_TOKEN: ${{ secrets.PAGERDUTY_API_TOKEN }}
        run: |
          set -euo pipefail
          missing=()
          if [ -z "${SLACK_WEBHOOK_URL:-}" ]; then missing+=(SLACK_WEBHOOK_URL); fi
          if [ -z "${PAGERDUTY_SERVICE_KEY:-}" ]; then missing+=(PAGERDUTY_SERVICE_KEY); fi
          if [ -z "${PAGERDUTY_API_TOKEN:-}" ]; then echo "PAGERDUTY_API_TOKEN: optional (recommended)"; fi
          if [ ${#missing[@]} -ne 0 ]; then
            echo "Missing secrets: ${missing[*]}"
            exit 0
          fi
          echo "All required secrets present"

      - name: Post results to issue
        if: always()
        env:
          ISSUE: ${{ github.event.inputs.notify_issue }}
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          set -euo pipefail
          STATUS_FILE=/tmp/secret_check.txt
          if grep -q 'Missing secrets' /github/workspace/.github/workflows/observability-e2e-secret-check.yml 2>/dev/null; then
            RESULT="Secret check failed"
          else
            # Re-run check quickly to build message
            missing=()
            if [ -z "${SLACK_WEBHOOK_URL:-}" ]; then missing+=(SLACK_WEBHOOK_URL); fi
            if [ -z "${PAGERDUTY_SERVICE_KEY:-}" ]; then missing+=(PAGERDUTY_SERVICE_KEY); fi
            if [ ${#missing[@]} -ne 0 ]; then
              RESULT="Missing secrets: ${missing[*]}"
            else
              RESULT="All required secrets present: SLACK_WEBHOOK_URL, PAGERDUTY_SERVICE_KEY (PAGERDUTY_API_TOKEN optional)"
            fi
          fi
          BODY=$(jq -n --arg b "$RESULT" '{body:$b}')
          curl -s -H "Authorization: Bearer $GITHUB_TOKEN" -H "Accept: application/vnd.github+json" \
            -X POST "https://api.github.com/repos/${{ github.repository }}/issues/$ISSUE/comments" -d "$BODY"
