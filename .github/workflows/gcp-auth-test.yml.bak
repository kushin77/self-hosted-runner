name: GCP Service Account Auth Test

on:
  workflow_dispatch:

permissions:
  id-token: write
  contents: read

jobs:
  verify:
    name: "Verify GCP authentication via OIDC"
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Authenticate to GCP
        id: auth
        uses: google-github-actions/auth@v2
        with:
          workload_identity_provider: ${{ secrets.GCP_WORKLOAD_IDENTITY_PROVIDER }}
          service_account: ${{ secrets.GCP_SERVICE_ACCOUNT_EMAIL }}

      - name: Check auth result
        run: |
          set -euo pipefail
          if [ "${{ steps.auth.outcome }}" = "success" ]; then
            echo "✅ GCP authentication succeeded"
            gcloud auth list || true
            gcloud config list || true
          else
            echo "❌ GCP authentication failed" >&2
            exit 1
          fi

      - name: Verify secret access (optional)
        if: steps.auth.outcome == 'success'
        run: |
          set -euo pipefail
          PROJECT=$(gcloud config get-value project || echo "${{ secrets.GCP_PROJECT_ID }}")
          echo "Testing read of GCP secret manager..."
          gcloud secrets versions access latest --secret=terraform-aws-prod --project="$PROJECT" || echo "⚠ couldn't read sample secret (ignore if not provisioned)"

      - name: Post result comment
        if: success()
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          gh issue comment 1309 --repo ${{ github.repository }} --body "✅ GCP service account authentication verified by gcp-auth-test workflow (run ${{ github.run_id }})." || true
