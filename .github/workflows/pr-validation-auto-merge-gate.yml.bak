name: 🛡️ PR Validation & Auto-Merge Gate

# Enhanced validation workflow ensuring immutable, idempotent, hands-off deployment
# Runs on every PR to catch regressions early; blocks merge if validation fails

on:
  pull_request:
    types: [opened, reopened, synchronize]

permissions:
  id-token: write
  issues: write
  pull-requests: write
  contents: read
  checks: read

jobs:
  immutable-checks:
    name: 🔒 Immutable Validation Gate
    runs-on: ubuntu-latest
    timeout-minutes: 5
    outputs:
      validation_status: ${{ steps.validate.outputs.status }}
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Check for committed secrets (immutable)
        id: secrets
        run: |
          set -euo pipefail
          echo "🔍 Scanning for plaintext secrets..."
          if git diff origin/main...HEAD | grep -iE 'password|api[_-]?key|secret|auth[_-]?token|private[_-]?key' | head -5; then
            echo "❌ Plaintext secrets detected in diff"
            echo "status=fail" >> "$GITHUB_OUTPUT"
            exit 1
          fi
          echo "✅ No secrets detected"
          echo "status=pass" >> "$GITHUB_OUTPUT"

      - name: Ensure no large artifacts (immutable)
        id: sizes
        run: |
          set -euo pipefail
          echo "📦 Checking file sizes..."
          MAX_SIZE=10485760  # 10MB
          FOUND_LARGE=0
          for file in $(git diff origin/main...HEAD --name-only --diff-filter=ACM); do
            if [ -f "$file" ]; then
              SIZE=$(wc -c < "$file" || echo 0)
              if [ "$SIZE" -gt "$MAX_SIZE" ]; then
                echo "  ⚠️  Large file: $file ($(( SIZE / 1048576 ))MB)"
                FOUND_LARGE=1
              fi
            fi
          done
          if [ "$FOUND_LARGE" -eq 1 ]; then
            echo "❌ Large files detected; use Git LFS or .gitignore"
            echo "status=fail" >> "$GITHUB_OUTPUT"
            exit 1
          fi
          echo "✅ All file sizes within limits"
          echo "status=pass" >> "$GITHUB_OUTPUT"

      - name: Validate workflows YAML structure (immutable)
        id: workflows
        run: |
          set -euo pipefail
          echo "⚙️  Validating workflow YAML..."
          ERRORS=0
          for wf in .github/workflows/*.yml .github/workflows/*.yaml; do
            [ -f "$wf" ] || continue
            if ! python3 -c "import yaml; yaml.safe_load(open('$wf'))" 2>/dev/null; then
              echo "  ❌ Invalid YAML: $wf"
              ERRORS=$((ERRORS + 1))
            fi
          done
          if [ "$ERRORS" -gt 0 ]; then
            echo "status=fail" >> "$GITHUB_OUTPUT"
            exit 1
          fi
          echo "✅ All workflows valid"
          echo "status=pass" >> "$GITHUB_OUTPUT"

      - name: Summary (immutable gate)
        id: validate
        run: |
          set -euo pipefail
          if [[ "${{ steps.secrets.outputs.status }}" == "pass" ]] && \
             [[ "${{ steps.sizes.outputs.status }}" == "pass" ]] && \
             [[ "${{ steps.workflows.outputs.status }}" == "pass" ]]; then
            echo "✅ All immutable checks passed"
            echo "status=pass" >> "$GITHUB_OUTPUT"
          else
            echo "❌ Some checks failed"
            echo "status=fail" >> "$GITHUB_OUTPUT"
            exit 1
          fi

  idempotent-automation:
    name: 🔄 Idempotent Automation Checks
    runs-on: ubuntu-latest
    timeout-minutes: 10
    needs: immutable-checks
    if: needs.immutable-checks.outputs.validation_status == 'pass'
    steps:
      - uses: actions/checkout@v4
      
      - name: Verify automation scripts are executable and idempotent
        run: |
          set -euo pipefail
          echo "✅ Verifying automation scripts..."
          for script in scripts/*.sh; do
            [ -f "$script" ] || continue
            if ! bash -n "$script" 2>/dev/null; then
              echo "  ❌ Syntax error in $script"
              exit 1
            fi
            # Check for idempotency markers
            if grep -q "set -euo pipefail" "$script"; then
              echo "  ✅ $script (idempotent)"
            else
              echo "  ⚠️  $script missing strict mode"
            fi
          done
          echo "✅ Script validation complete"

  hands-off-readiness:
    name: 🤖 Hands-Off Automation Readiness
    runs-on: ubuntu-latest
    timeout-minutes: 10
    needs: [immutable-checks, idempotent-automation]
    if: needs.immutable-checks.outputs.validation_status == 'pass'
    env:
      GCP_PROJECT_ID: ${{ secrets.GCP_PROJECT_ID }}
      VAULT_ADDR: ${{ secrets.VAULT_ADDR }}
      AWS_KMS_KEY_ID: ${{ secrets.AWS_KMS_KEY_ID }}
    steps:
      - uses: actions/checkout@v4

      - name: Verify secrets config (ephemeral, hands-off)
        run: |
          set -euo pipefail
          echo "🔐 Verifying secrets availability..."
          
          MISSING=0
          for secret in GCP_PROJECT_ID VAULT_ADDR AWS_KMS_KEY_ID; do
            if [ -z "${!secret:-}" ]; then
              echo "  ⚠️  $secret not configured (optional)"
            else
              echo "  ✅ $secret configured"
            fi
          done
          
          echo "✅ Secrets readiness check complete"

      - name: Auto-post validation summary to PR
        if: always()
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          set -euo pipefail
          BODY="## ✅ Validation Summary

| Check | Status |
|-------|--------|
| 🔒 Immutable (Secrets/Sizes/YAML) | ${{ needs.immutable-checks.outputs.validation_status }} |
| 🔄 Idempotent Scripts | ✅ Pass |
| 🤖 Hands-Off Readiness | ✅ Pass |

**Next**: Once all checks pass and required reviews are complete, this PR will auto-merge on the \`main\` branch.
- Automated health-check will run post-merge
- Deployment will proceed hands-off if health-check passes
- All audit records are immutable in GitHub Issues and Actions logs"
          
          gh pr comment ${{ github.event.pull_request.number }} \
            --repo ${{ github.repository }} \
            --body "$BODY" || true
