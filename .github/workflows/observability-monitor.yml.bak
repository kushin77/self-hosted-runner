name: Observability E2E Monitor
permissions:
  contents: read
  id-token: write
  actions: read

on:
  workflow_run:
    workflows: ["Observability E2E Test"]
    types: [completed]

jobs:
  handle-run:
    name: Handle Observability E2E Run
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Set variables
        id: vars
        run: |
          echo "CONCLUSION=${{ github.event.workflow_run.conclusion || 'unknown' }}" >> $GITHUB_OUTPUT
          echo "RUN_URL=${{ github.event.workflow_run.html_url || '' }}" >> $GITHUB_OUTPUT

      - name: Create/update alert on failure and notify Slack (optional)
        if: ${{ startsWith(ne(github.event.workflow_run.conclusion, 'success'), true) }}
        uses: actions/github-script@v6
        with:
          script: |
            const conclusion = process.env.CONCLUSION || context.payload.workflow_run.conclusion || 'unknown';
            const runUrl = process.env.RUN_URL || context.payload.workflow_run.html_url || '';
            const title = 'Alert: Observability E2E failed';
            const body = `The "Observability E2E Test" workflow completed with conclusion: **${conclusion}**\n\nRun URL: ${runUrl}\n\nThis alert was created automatically by the observability monitor workflow. Please investigate failures and attach logs.`;

            // find existing open issue
            const { data: issues } = await github.rest.issues.listForRepo({ owner: context.repo.owner, repo: context.repo.repo, state: 'open' });
            const existing = issues.find(i => i.title === title);

            let issueNumber;
            if (existing) {
              issueNumber = existing.number;
              await github.rest.issues.createComment({ owner: context.repo.owner, repo: context.repo.repo, issue_number: issueNumber, body });
              await github.rest.issues.addLabels({ owner: context.repo.owner, repo: context.repo.repo, issue_number: issueNumber, labels: ['observability', 'e2e-failure'] }).catch(()=>{});
              core.info(`Appended comment to existing issue #${issueNumber}`);
            } else {
              const created = await github.rest.issues.create({ owner: context.repo.owner, repo: context.repo.repo, title, body, labels: ['observability','e2e-failure'] });
              issueNumber = created.data.number;
              core.info(`Created alert issue #${issueNumber}`);
            }

            // Optionally notify Slack if secret available (non-fatal)
            const slackUrl = process.env.SLACK_WEBHOOK_URL || '';
            if (slackUrl) {
              try {
                await require('node-fetch')(slackUrl, {
                  method: 'POST',
                  body: JSON.stringify({ text: `Observability E2E failure: ${runUrl} (issue #${issueNumber})` }),
                  headers: { 'Content-Type': 'application/json' }
                });
                core.info('Posted notification to Slack');
              } catch (e) {
                core.warning('Failed to post to Slack: ' + e.message);
              }
            }

            // Optionally notify PagerDuty via Events API v2 when key available (non-fatal)
            const pagerKey = process.env.PAGERDUTY_SERVICE_KEY || '';
            if (pagerKey) {
              try {
                const pdBody = {
                  routing_key: pagerKey,
                  event_action: 'trigger',
                  payload: {
                    summary: `Observability E2E failure - ${runUrl}`,
                    severity: 'error',
                    source: 'github.actions'
                  }
                };
                await require('node-fetch')('https://events.pagerduty.com/v2/enqueue', {
                  method: 'POST',
                  body: JSON.stringify(pdBody),
                  headers: { 'Content-Type': 'application/json' }
                });
                core.info('Triggered PagerDuty event');
              } catch (e) {
                core.warning('Failed to trigger PagerDuty event: ' + e.message);
              }
            }

            // Optionally assign issue when ALERT_ASSIGNEE provided
            const assignee = process.env.ALERT_ASSIGNEE || '';
            if (assignee && issueNumber) {
              try {
                await github.rest.issues.addAssignees({ owner: context.repo.owner, repo: context.repo.repo, issue_number: issueNumber, assignees: [assignee] });
                core.info(`Assigned issue #${issueNumber} to ${assignee}`);
              } catch (e) {
                core.warning('Failed to assign issue: ' + e.message);
              }
            }

      - name: Close alert on success
        if: ${{ github.event.workflow_run.conclusion == 'success' }}
        uses: actions/github-script@v6
        with:
          script: |
            const title = 'Alert: Observability E2E failed';
            // find existing open issue
            const { data: issues } = await github.rest.issues.listForRepo({ owner: context.repo.owner, repo: context.repo.repo, state: 'open' });
            const existing = issues.find(i => i.title === title);
            if (existing) {
              await github.rest.issues.createComment({ owner: context.repo.owner, repo: context.repo.repo, issue_number: existing.number, body: 'Observability E2E succeeded on a subsequent run — closing alert automatically.' });
              await github.rest.issues.update({ owner: context.repo.owner, repo: context.repo.repo, issue_number: existing.number, state: 'closed' });
              core.info(`Closed alert issue #${existing.number}`);
            } else {
              core.info('No open alert issue to close');
            }
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
      
      - name: Export secrets for js step
        run: |
          if [ "${{ secrets.SLACK_WEBHOOK_URL || '' }}" != "" ]; then echo "SLACK_WEBHOOK_URL=${{ secrets.SLACK_WEBHOOK_URL }}" >> $GITHUB_ENV; fi
          if [ "${{ secrets.PAGERDUTY_SERVICE_KEY || '' }}" != "" ]; then echo "PAGERDUTY_SERVICE_KEY=${{ secrets.PAGERDUTY_SERVICE_KEY }}" >> $GITHUB_ENV; fi
          if [ "${{ secrets.ALERT_ASSIGNEE || '' }}" != "" ]; then echo "ALERT_ASSIGNEE=${{ secrets.ALERT_ASSIGNEE }}" >> $GITHUB_ENV; fi