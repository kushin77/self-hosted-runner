name: One-off Terraform Instant Deploy

on:
  workflow_dispatch: {}

permissions:
  contents: read
  id-token: write
  issues: write

jobs:
  deploy:
    name: One-off Deploy (Vault-first)
    runs-on: ubuntu-latest
    env:
      VAULT_ADDR: ${{ secrets.VAULT_ADDR }}
      VAULT_NAMESPACE: ${{ secrets.VAULT_NAMESPACE }}
      VAULT_ROLE_ID: ${{ secrets.VAULT_ROLE_ID }}
      VAULT_SECRET_ID: ${{ secrets.VAULT_SECRET_ID }}
      GCP_PROJECT_ID: ${{ secrets.GCP_PROJECT_ID }}
      GCP_SERVICE_ACCOUNT_KEY_JSON: ${{ secrets.GCP_SERVICE_ACCOUNT_KEY_JSON }}
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Terraform
        uses: hashicorp/setup-terraform@v2
        with:
          terraform_version: '1.4.0'

      - name: Run unified credential fetch (Vault-first)
        id: fetch
        run: |
          set -euo pipefail
          export CREDENTIAL_PREFERENCE=VAULT
          bash scripts/ops/fetch-creds-unified.sh

      - name: Configure AWS creds from fetch
        run: |
          set -euo pipefail
          echo "AWS_ACCESS_KEY_ID=${{ steps.fetch.outputs.aws_access_key_id }}" >> $GITHUB_ENV
          echo "AWS_SECRET_ACCESS_KEY=${{ steps.fetch.outputs.aws_secret_access_key }}" >> $GITHUB_ENV
          echo "AWS_DEFAULT_REGION=${{ steps.fetch.outputs.aws_region }}" >> $GITHUB_ENV

      - name: Terraform Init
        working-directory: terraform
        run: terraform init -input=false

      - name: Terraform Plan
        working-directory: terraform
        run: |
          set -euo pipefail
          terraform plan -input=false -out=tfplan

      - name: Terraform Apply
        working-directory: terraform
        run: |
          set -euo pipefail
          terraform apply -input=false -auto-approve tfplan

      - name: Post Apply Validation
        run: |
          set -euo pipefail
          bash scripts/ops/validate-post-apply.sh --namespace kube-system || true

      - name: Post results to issues
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          set -euo pipefail
          gh issue comment 1286 --body "One-off deploy run completed (see actions)" || true
          gh issue comment 1309 --body "One-off deploy run completed (see actions)" || true
