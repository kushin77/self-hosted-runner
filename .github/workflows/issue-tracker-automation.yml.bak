name: Issue Tracker Automation (Idempotent)

on:
  schedule:
    - cron: '0 */4 * * *'  # Every 4 hours
  workflow_dispatch:

permissions:
  issues: write
  contents: read
  actions: read

jobs:
  manage-tracking-issues:
    name: Manage and Update Tracking Issues (Idempotent)
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Check critical secrets for provisioning status
        id: secrets
        env:
          GCP_WORKLOAD_IDENTITY_PROVIDER: ${{ secrets.GCP_WORKLOAD_IDENTITY_PROVIDER }}
          AWS_OIDC_ROLE_ARN: ${{ secrets.AWS_OIDC_ROLE_ARN }}
          USE_OIDC: ${{ secrets.USE_OIDC }}
        run: |
          echo "Checking provisioning status..."

          # GCP WI status
          if [ -n "${GCP_WORKLOAD_IDENTITY_PROVIDER}" ]; then
            echo "gcp_wi_status=provisioned" >> $GITHUB_OUTPUT
          else
            echo "gcp_wi_status=pending" >> $GITHUB_OUTPUT
          fi

          # AWS OIDC status
          if [ -n "${AWS_OIDC_ROLE_ARN}" ] && [ "${USE_OIDC}" = "true" ]; then
            echo "aws_oidc_status=provisioned" >> $GITHUB_OUTPUT
          else
            echo "aws_oidc_status=pending" >> $GITHUB_OUTPUT
          fi

          # Overall readiness
          if [ -n "${GCP_WORKLOAD_IDENTITY_PROVIDER}" ] && [ -n "${AWS_OIDC_ROLE_ARN}" ]; then
            echo "automation_ready=true" >> $GITHUB_OUTPUT
          else
            echo "automation_ready=false" >> $GITHUB_OUTPUT
          fi

      - name: Create/update issue #1309 (Terraform Auto-Apply)
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          REPO="${{ github.repository }}"

          # Check if issue exists (idempotent)
          ISSUE_EXISTS=$(gh issue list --repo ${REPO} --state all --json number --jq '.[] | select(.number==1309) | .number' 2>/dev/null || echo "")

          if [ -z "$ISSUE_EXISTS" ]; then
            # Create issue
            gh issue create --repo ${REPO} \
              --title "Terraform Auto-Apply: Provisioning AWS OIDC Role" \
              --body "**Status**: 🟡 Awaiting operator provisioning \n\n**Tracking**: Terraform auto-apply workflow readiness for credential-driven infrastructure deployment.\n\n**Blocker**: AWS OIDC role ARN secret not configured.\n\n**Required Actions**:\n1. Provision AWS OIDC role (see OPERATOR_REMEDIATION_AUTOMATION_RUNBOOK.md, Phase 2)\n2. Set repo secret AWS_OIDC_ROLE_ARN\n3. Set repo secret USE_OIDC=true\n4. This issue will auto-close when provisioning complete.\n\n**Related**: Issue #1346 (AWS OIDC provisioning)" \
              --label "auto-provisioning,terraform" || true
          else
            # Issue exists; update status if needed
            GCP_WI="${{ steps.secrets.outputs.gcp_wi_status }}"
            AWS_OIDC="${{ steps.secrets.outputs.aws_oidc_status }}"

            if [ "$AWS_OIDC" = "provisioned" ]; then
              BODY="**Status**: ✅ AWS OIDC Role Provisioned\n\n✅ AWS_OIDC_ROLE_ARN configured\n✅ USE_OIDC=true enabled\n\nTerraform auto-apply ready. Infrastructure changes will auto-apply on push to terraform/**\n\nClosing this issue."
              gh issue comment 1309 --repo ${REPO} --body "$BODY" || true
              gh issue close 1309 --repo ${REPO} --comment "Provisioning complete." || true
            else
              BODY="**Status Update**: Awaiting AWS OIDC role provisioning. GCP WI Status: ${GCP_WI}. AWS OIDC Status: ${AWS_OIDC}."
              # Check if we already have a recent status comment
              LAST_COMMENT=$(gh issue view 1309 --repo ${REPO} --json comments --jq '.comments[-1].body' 2>/dev/null || echo "")
              if ! echo "$LAST_COMMENT" | grep -q "Status Update"; then
                gh issue comment 1309 --repo ${REPO} --body "$BODY" || true
              fi
            fi
          fi

      - name: Create/update issue #1346 (AWS OIDC Provisioning)
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          REPO="${{ github.repository }}"

          ISSUE_EXISTS=$(gh issue list --repo ${REPO} --state all --json number --jq '.[] | select(.number==1346) | .number' 2>/dev/null || echo "")

          if [ -z "$ISSUE_EXISTS" ]; then
            gh issue create --repo ${REPO} \
              --title "AWS OIDC Role Provisioning (Operator Action)" \
              --body "**Status**: 🟡 Awaiting operator provisioning\n\n**Task**: Provision AWS OIDC role for GitHub Actions Terraform automation.\n\n**Steps**:\n1. See OPERATOR_REMEDIATION_AUTOMATION_RUNBOOK.md, Phase 2\n2. Create GitHub Actions OIDC provider in AWS\n3. Create IAM role with trust policy\n4. Attach required Terraform permissions\n5. Set repo secret AWS_OIDC_ROLE_ARN\n6. Enable USE_OIDC=true\n\n**Automation Impact**: Unlocks terraform-auto-apply.yml fully hands-off execution.\n\n**Related**: Issue #1309" \
              --label "auto-provisioning,aws,oidc" || true
          else
            AWS_OIDC="${{ steps.secrets.outputs.aws_oidc_status }}"
            if [ "$AWS_OIDC" = "provisioned" ]; then
              BODY="**Status**: ✅ AWS OIDC Role Successfully Provisioned\n\n- AWS_OIDC_ROLE_ARN: ✅ Configured\n- USE_OIDC: ✅ Enabled\n\nClosing this issue."
              gh issue comment 1346 --repo ${REPO} --body "$BODY" || true
              gh issue close 1346 --repo ${REPO} --comment "Provisioning complete." || true
            fi
          fi

      - name: Create/update issue #1324 (ElastiCache Automation)
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          REPO="${{ github.repository }}"

          ISSUE_EXISTS=$(gh issue list --repo ${REPO} --state all --json number --jq '.[] | select(.number==1324) | .number' 2>/dev/null || echo "")

          if [ -z "$ISSUE_EXISTS" ]; then
            gh issue create --repo ${REPO} \
              --title "ElastiCache Automation: Safe Apply with Approval Gates" \
              --body "**Status**: ✅ Implementation Complete\n\n**Completed**:\n✅ Dry-run plan artifact generation (JSON + binary)\n✅ Plan portability (version-independent JSON rendering)\n✅ Approval gates for safety\n✅ MinIO integration for self-hosted runners\n\n**Feature**: elasticache-apply-safe.yml now supports:\n- Conditional credential detection\n- Safe dry-run when credentials unavailable\n- Plan review via JSON artifacts\n- Automatic issue commenting\n\n**Next**: Operator provisions AWS credentials (see Issue #1346) to enable full apply.\n\nClosing as completed." \
              --label "auto-provisioning,elasticache" || true
            gh issue close $(gh issue list --repo ${REPO} --state open --json number --jq '.[] | select(.title | contains(\"ElastiCache\")) | .number' 2>/dev/null || echo "1324") --repo ${REPO} --comment "ElastiCache automation feature complete." || true
          else
            # Check if already closed
            STATE=$(gh issue view 1324 --repo ${REPO} --json state --jq '.state' 2>/dev/null || echo "")
            if [ "$STATE" != "CLOSED" ]; then
              gh issue close 1324 --repo ${REPO} --comment "ElastiCache dry-run and approval gates complete." || true
            fi
          fi

      - name: Ensure issue #1064 (System Status) exists and is open
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          REPO="${{ github.repository }}"

          ISSUE_EXISTS=$(gh issue view 1064 --repo ${REPO} --json number 2>/dev/null || echo "")

          if [ -z "$ISSUE_EXISTS" ]; then
            gh issue create --repo ${REPO} \
              --title "System Status Aggregator Tracking" \
              --body "**Purpose**: Central tracking issue for system health dashboard.\n\nThis issue receives automated status reports every 15 minutes from system-status-aggregator.yml.\n\n**Status**: Awaiting operator provisioning to reach full automation readiness.\n\n**Related**: #1309, #1346, #1324" \
              --label "automation,status-tracking" || true
          else
            ISSUE_STATE=$(gh issue view 1064 --repo ${REPO} --json state --jq '.state' 2>/dev/null || echo "")
            if [ "$ISSUE_STATE" = "CLOSED" ]; then
              gh issue reopen 1064 --repo ${REPO} || true
            fi
          fi

      - name: Final status summary
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          GCP_WI="${{ steps.secrets.outputs.gcp_wi_status }}"
          AWS_OIDC="${{ steps.secrets.outputs.aws_oidc_status }}"
          READY="${{ steps.secrets.outputs.automation_ready }}"

          echo "---"
          echo "📊 Automation Provisioning Status"
          echo "---"
          echo "GCP Workload Identity: $GCP_WI"
          echo "AWS OIDC Role: $AWS_OIDC"
          echo "Automation Ready: $READY"
          echo ""

          if [ "$READY" = "true" ]; then
            echo "✅ ALL CREDENTIALS PROVISIONED!"
            echo "Fully hands-off automation is now active:"
            echo "  - terraform-auto-apply.yml: Auto-applies on terraform/** push"
            echo "  - elasticache-apply-safe.yml: Auto-applies on tfvars push"
            echo "  - system-status-aggregator.yml: Reports health every 15 min"
          else
            echo "🟡 AWAITING PROVISIONING"
            echo "Complete operator runbook at: OPERATOR_REMEDIATION_AUTOMATION_RUNBOOK.md"
            echo ""
            echo "Missing:"
            [ "$GCP_WI" = "pending" ] && echo "  - GCP Workload Identity setup (Phase 1)"
            [ "$AWS_OIDC" = "pending" ] && echo "  - AWS OIDC role provisioning (Phase 2)"
          fi
