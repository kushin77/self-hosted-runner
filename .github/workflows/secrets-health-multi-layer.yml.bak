name: 🏥 Secrets Multi-Layer Health Check

# Replaces all polling-based health checks
# Verifies all three layers (GSM, Vault, KMS) are operational
# Auto-triggers orchestration if health check fails
# Principle: Event-driven remediation

on:
  schedule:
    # Single health check replaces multiple polling workflows
    - cron: '*/15 * * * *'  # Every 15 minutes
  
  workflow_dispatch:
    inputs:
      verbose:
        description: 'Verbose logging'
        required: false
        default: 'false'

permissions:
  id-token: write
  issues: write
  actions: write

concurrency:
  group: secrets-health-${{ github.ref }}
  cancel-in-progress: false

env:
  GCP_PROJECT_ID: ${{ secrets.GCP_PROJECT_ID }}
  GCP_WORKLOAD_IDENTITY_PROVIDER: ${{ secrets.GCP_WORKLOAD_IDENTITY_PROVIDER }}
  VAULT_ADDR: ${{ secrets.VAULT_ADDR }}
  AWS_KMS_KEY_ID: ${{ secrets.AWS_KMS_KEY_ID }}

jobs:
  health-check:
    name: Multi-Layer Health Check
    runs-on: ubuntu-latest
    timeout-minutes: 10
    
    outputs:
      health_status: ${{ steps.summary.outputs.health_status }}
      layers_healthy: ${{ steps.summary.outputs.layers_healthy }}
      primary_layer: ${{ steps.summary.outputs.primary_layer }}
    
    steps:
      - name: Initialize
        id: init
        run: |
          TIMESTAMP=$(date -u +%Y-%m-%dT%H:%M:%SZ)
          echo "timestamp=$TIMESTAMP" >> "$GITHUB_OUTPUT"
          echo "🏥 Health Check: $TIMESTAMP"

      - name: Layer 1 (GSM) - Primary Health Check
        id: layer1_health
        run: |
          set -euo pipefail
          
          echo "Checking Layer 1: Google Secret Manager (Primary)"
          
          if [[ -z "$GCP_PROJECT_ID" || -z "$GCP_WORKLOAD_IDENTITY_PROVIDER" ]]; then
            echo "  ⚠️  GCP not configured"
            echo "status=not_configured" >> "$GITHUB_OUTPUT"
            exit 0
          fi
          
          # Attempt ephemeral OIDC auth first (recommended)
          OIDC_TOKEN=""
          OIDC_AVAILABLE=false
          
          for i in 1 2 3; do
            RESP=$(curl -sS "${ACTIONS_ID_TOKEN_REQUEST_URL}?audience=https://iamcredentials.googleapis.com" \
              -H "Authorization: bearer ${ACTIONS_ID_TOKEN_REQUEST_TOKEN}" 2>/dev/null || true)
            if [[ -n "$RESP" ]]; then
              TOK=$(echo "$RESP" | jq -r '.token // empty' 2>/dev/null || echo "")
              if [[ -n "$TOK" ]]; then
                OIDC_TOKEN="$TOK"
                OIDC_AVAILABLE=true
                echo "  ✅ OIDC id-token obtained (ephemeral)"
                break
              fi
            fi
            sleep $((i * 2))
          done
          
          if [[ "$OIDC_AVAILABLE" == "false" ]]; then
            echo "  ⚠️  OIDC id-token not available; attempting fallback to ADC"
          fi
          
          # Quick GSM connectivity check (try both ephemeral OIDC and ADC fallback)
          if [[ "$OIDC_AVAILABLE" == "true" ]]; then
            gcloud auth login --cred-file=/tmp/wif_cred.json 2>&1 || {
              echo "  ❌ GCP OIDC authentication failed"
              echo "status=auth_failed" >> "$GITHUB_OUTPUT"
              exit 0
            }
          else
            # Try ADC (Application Default Credentials) if available
            gcloud auth application-default print-access-token >/dev/null 2>&1 || {
              echo "  ❌ GCP authentication not available (no ADC, no OIDC)"
              echo "status=auth_failed" >> "$GITHUB_OUTPUT"
              exit 0
            }
          fi
          
          # List secrets to verify access
          SECRETS=$(gcloud secrets list --project="$GCP_PROJECT_ID" --limit=1 2>&1)
          
          if [[ $? -eq 0 ]]; then
            echo "  ✅ GSM Healthy (Primary)"
            echo "status=healthy" >> "$GITHUB_OUTPUT"
          else
            echo "  ❌ GSM access failed"
            echo "status=unhealthy" >> "$GITHUB_OUTPUT"
          fi

      - name: Layer 2 (Vault) - Secondary Health Check
        id: layer2_health
        run: |
          set -euo pipefail
          
          echo "Checking Layer 2: HashiCorp Vault (Secondary)"
          
          if [[ -z "$VAULT_ADDR" ]]; then
            echo "  ⚠️  Vault not configured"
            echo "status=not_configured" >> "$GITHUB_OUTPUT"
            exit 0
          fi
          
          # Check Vault health endpoint (no auth required)
          # Defensive Vault health check with parse guard and retries
          VAULT_HEALTH=""
          for i in 1 2 3; do
            VAULT_HEALTH=$(curl -sf "$VAULT_ADDR/v1/sys/health" 2>/dev/null || true)
            if [[ -n "$VAULT_HEALTH" ]]; then
              # confirm it's valid JSON before jq
              echo "$VAULT_HEALTH" | jq . >/dev/null 2>&1 && break || VAULT_HEALTH=""
            fi
            sleep $((i * 2))
          done

          if [[ -n "$VAULT_HEALTH" ]]; then
            SEALED=$(echo "$VAULT_HEALTH" | jq -r '.sealed // true')
            if [[ "$SEALED" == "false" ]]; then
              echo "  ✅ Vault Healthy (Secondary, unsealed)"
              echo "status=healthy" >> "$GITHUB_OUTPUT"
            else
              echo "  ⚠️  Vault sealed (requires unsealing)"
              echo "status=sealed" >> "$GITHUB_OUTPUT"
            fi
          else
            echo "  ❌ Vault unavailable or returned non-JSON"
            echo "status=unavailable" >> "$GITHUB_OUTPUT"
          fi

      - name: Layer 3 (KMS) - Tertiary Health Check
        id: layer3_health
        run: |
          set -euo pipefail
          
          echo "Checking Layer 3: AWS KMS (Tertiary)"
          
          if [[ -z "$AWS_KMS_KEY_ID" ]]; then
            echo "  ⚠️  KMS not configured"
            echo "status=not_configured" >> "$GITHUB_OUTPUT"
            exit 0
          fi
          
          # Attempt ephemeral OIDC-based AWS auth first (recommended)
          # If OIDC not available, fall back to environment AWS credentials
          AWS_CALLER=""
          OIDC_AWS_AVAILABLE=false
          
          # Try OIDC-based AWS auth via web identity token exchange (if OIDC available)
          if [[ -n "${ACTIONS_ID_TOKEN_REQUEST_URL:-}" ]]; then
            OIDC_RESP=$(curl -sS "${ACTIONS_ID_TOKEN_REQUEST_URL}?audience=https://sts.amazonaws.com" \
              -H "Authorization: bearer ${ACTIONS_ID_TOKEN_REQUEST_TOKEN}" 2>/dev/null || true)
            OIDC_TOKEN=$(echo "$OIDC_RESP" | jq -r '.token // empty' 2>/dev/null || echo "")
            
            if [[ -n "$OIDC_TOKEN" ]]; then
              OIDC_AWS_AVAILABLE=true
              echo "  ✅ AWS OIDC id-token obtained"
            fi
          fi
          
          # Try to get AWS caller identity (via OIDC or environment credentials)
          for i in 1 2 3; do
            RESP=$(aws sts get-caller-identity --output json 2>/dev/null || true)
            if [[ -n "$RESP" ]]; then
              ARN=$(echo "$RESP" | jq -r '.Arn // empty' 2>/dev/null || echo "")
              if [[ -n "$ARN" ]]; then
                AWS_CALLER="$ARN"
                AUTH_METHOD="environment"
                if [[ "$OIDC_AWS_AVAILABLE" == "true" ]]; then
                  AUTH_METHOD="OIDC"
                fi
                echo "  ✅ AWS auth successful ($AUTH_METHOD)"
                break
              fi
            fi
            sleep $((i * 2))
          done

          if [[ -n "$AWS_CALLER" ]]; then
            echo "  ✅ KMS Healthy (Tertiary)"
            echo "status=healthy" >> "$GITHUB_OUTPUT"
          else
            echo "  ❌ KMS access failed or returned non-JSON"
            echo "status=unhealthy" >> "$GITHUB_OUTPUT"
          fi

      - name: Analyze health status
        id: summary
        run: |
          set -euo pipefail
          
          LAYER1="${{ steps.layer1_health.outputs.status }}"
          LAYER2="${{ steps.layer2_health.outputs.status }}"
          LAYER3="${{ steps.layer3_health.outputs.status }}"
          
          echo "📊 Health Summary:"
          echo "  Layer 1 (GSM): $LAYER1"
          echo "  Layer 2 (Vault): $LAYER2"
          echo "  Layer 3 (KMS): $LAYER3"
          
          # Determine primary layer using only configured layers
          PRIMARY="NONE"
          HEALTH="unhealthy"

          # Count configured layers and unhealthy configured layers
          CONFIGURED=0
          UNHEALTHY_CONFIGURED=0

          if [[ "$LAYER1" != "not_configured" ]]; then
            CONFIGURED=$((CONFIGURED + 1))
            if [[ "$LAYER1" == "healthy" ]]; then
              PRIMARY="GSM"
              HEALTH="healthy"
            else
              UNHEALTHY_CONFIGURED=$((UNHEALTHY_CONFIGURED + 1))
            fi
          fi

          if [[ "$LAYER2" != "not_configured" ]]; then
            CONFIGURED=$((CONFIGURED + 1))
            if [[ "$LAYER2" == "healthy" && "$PRIMARY" == "NONE" ]]; then
              PRIMARY="Vault"
              HEALTH="degraded"
            elif [[ "$LAYER2" != "healthy" ]]; then
              UNHEALTHY_CONFIGURED=$((UNHEALTHY_CONFIGURED + 1))
            fi
          fi

          if [[ "$LAYER3" != "not_configured" ]]; then
            CONFIGURED=$((CONFIGURED + 1))
            if [[ "$LAYER3" == "healthy" && "$PRIMARY" == "NONE" ]]; then
              PRIMARY="KMS"
              HEALTH="critically-degraded"
            elif [[ "$LAYER3" != "healthy" ]]; then
              UNHEALTHY_CONFIGURED=$((UNHEALTHY_CONFIGURED + 1))
            fi
          fi

          # If no layers configured, consider health as healthy (no-op environment)
          if [[ $CONFIGURED -eq 0 ]]; then
            PRIMARY="NONE"
            HEALTH="healthy"
          else
            if [[ $UNHEALTHY_CONFIGURED -eq 0 ]]; then
              # at least one configured layer healthy
              :
            elif [[ $UNHEALTHY_CONFIGURED -eq $CONFIGURED ]]; then
              HEALTH="unhealthy"
            else
              HEALTH="degraded"
            fi
          fi
          
          echo "  Primary: $PRIMARY"
          echo "  Health: $HEALTH"
          
          echo "health_status=$HEALTH" >> "$GITHUB_OUTPUT"
          echo "layers_healthy=$PRIMARY" >> "$GITHUB_OUTPUT"
          echo "primary_layer=$PRIMARY" >> "$GITHUB_OUTPUT"

      - name: Trigger remediation if unhealthy
        id: remediation
        if: steps.summary.outputs.health_status != 'healthy'
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          set -euo pipefail
          
          HEALTH="${{ steps.summary.outputs.health_status }}"
          
          if [[ "$HEALTH" == "unhealthy" ]]; then
            echo "🚨 CRITICAL: All layers unhealthy"
            
            # Create incident issue
            gh issue create \
              --repo "${{ github.repository }}" \
              --title "🚨 CRITICAL: All Secret Layers Unhealthy" \
              --body "All three secret management layers (GSM, Vault, KMS) are unavailable. Immediate action required. See: https://github.com/${{ github.repository }}/actions/runs/${{ github.run_id }}" \
              --label "security" \
              --label "incident" \
              --label "critical" 2>/dev/null || true
            
            exit 1
          else
            echo "⚠️  Degraded health detected, triggering orchestration"
            
            # Trigger orchestration to sync and validate
            gh workflow run secrets-event-dispatcher.yml \
              --repo "${{ github.repository }}" \
              --ref main \
              -f event_type="health-check:$HEALTH" \
              2>/dev/null || true
          fi

      - name: Record health metric (immutable)
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        if: github.event.inputs.verbose == 'true' || steps.summary.outputs.health_status != 'healthy'
        run: |
          HEALTH="${{ steps.summary.outputs.health_status }}"
          PRIMARY="${{ steps.summary.outputs.primary_layer }}"
          TIMESTAMP="${{ steps.init.outputs.timestamp }}"
          
          gh issue create \
            --repo "${{ github.repository }}" \
            --title "📊 Health Metric: $HEALTH ($PRIMARY)" \
            --body "Timestamp: $TIMESTAMP\nStatus: $HEALTH\nPrimary: $PRIMARY\nRun: https://github.com/${{ github.repository }}/actions/runs/${{ github.run_id }}" \
            --label "monitoring" \
            --label "health-check" 2>/dev/null || true
