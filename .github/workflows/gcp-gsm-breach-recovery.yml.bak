# ⚠️ DISABLED - gcp-gsm-breach-recovery.yml
# This workflow has YAML syntax errors and has been disabled to prevent cascading failures.
# Root cause: Corrupted redacted secret placeholders in workflow definition
# Status: Can be executed manually via: gh workflow run gcp-gsm-breach-recovery.yml --ref main
# Remediation: See https://github.com/kushin77/self-hosted-runner/issues/1979
#
name: GCP GSM Emergency Breach Recovery

on:
  workflow_dispatch:
    inputs:
      action:
        description: 'Emergency action to perform'
        required: true
        default: 'revoke'
        type: choice
        options:
          - revoke
          - compromise
          - exposure
          - mass-rotate
          - verify
          - audit
      secret_name:
        description: 'Secret name (required for revoke/compromise/exposure/verify)'
        required: false
      reason:
        description: 'Reason for emergency action (e.g., "github_leak", "logs_exposed")'
        required: false
  issue_comment:
    types: [created, edited]

permissions:
  contents: read
  id-token: write
  issues: write

jobs:
  emergency-response:
    name: Emergency GSM Response
    runs-on: ubuntu-latest
    if: >
      github.event_name == 'workflow_dispatch' ||
      (github.event_name == 'issue_comment' &&
       contains(github.event.issue.labels.*.name, 'emergency') &&
       (contains(github.event.comment.body, '/breach') ||
        contains(github.event.comment.body, '/revoke-secret') ||
        contains(github.event.comment.body, '/emergency-rotate')))
    timeout-minutes: 10

    env:
      GCP_PROJECT_ID: ${{ secrets.GCP_PROJECT_ID }}

    outputs:
      incident_id: ${{ steps.response.outputs.incident_id }}
      action_taken: ${{ steps.response.outputs.action }}

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Parse emergency command from comment
        id: parse-command
        if: github.event_name == 'issue_comment'
        run: |
          COMMENT="${{ github.event.comment.body }}"

          if [[ "$COMMENT" =~ /breach[[:space:]]+([^[:space:]]+)[[:space:]]*([^[:space:]]*)? ]]; then
            echo "action=compromise" >> $GITHUB_OUTPUT
            echo "secret=${BASH_REMATCH[1]}" >> $GITHUB_OUTPUT
            echo "reason=${BASH_REMATCH[2]:-detected}" >> $GITHUB_OUTPUT
          elif [[ "$COMMENT" =~ /revoke-secret[[:space:]]+([^[:space:]]+) ]]; then
            echo "action=revoke" >> $GITHUB_OUTPUT
            echo "secret=${BASH_REMATCH[1]}" >> $GITHUB_OUTPUT
          elif [[ "$COMMENT" =~ /emergency-rotate ]]; then
            echo "action=mass-rotate" >> $GITHUB_OUTPUT
          fi
        continue-on-error: true

      - name: Authenticate to Google Cloud
        uses: google-github-actions/auth@v2
        with:
          workload_identity_provider: ${{ secrets.GCP_WORKLOAD_IDENTITY_PROVIDER }}
          service_account_email: ${{ secrets.GCP_SERVICE_ACCOUNT_EMAIL }}
          credentials_json: ${{ secrets.GCP_SERVICE_ACCOUNT_KEY }}
          create_credentials_file: true
          export_environment_variables: true

      - name: Setup gcloud CLI
        uses: google-github-actions/setup-gcloud@v2
        with:
          project_id: ${{ secrets.GCP_PROJECT_ID }}

      - name: Make emergency script executable
        run: chmod +x scripts/automation/gcp-gsm-emergency-recovery.sh

      - name: Execute emergency response
        id: response
        run: |
          ACTION="${{ inputs.action || steps.parse-command.outputs.action || 'help' }}"
          SECRET="${{ inputs.secret_name || steps.parse-command.outputs.secret || '' }}"
          REASON="${{ inputs.reason || steps.parse-command.outputs.reason || 'emergency' }}"

          INCIDENT_ID="INCIDENT-$(date +%s)-$(echo $RANDOM | md5sum | cut -c1-6)"

          echo "incident_id=$INCIDENT_ID" >> $GITHUB_OUTPUT
          echo "action=$ACTION" >> $GITHUB_OUTPUT

          echo "🚨 Emergency Response Initiated"
          echo "  Incident ID: $INCIDENT_ID"
          echo "  Action: $ACTION"
          echo "  Secret: $SECRET"
          echo "  Reason: $REASON"
          echo "  Timestamp: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
          echo ""

          case "$ACTION" in
            revoke)
              [[ -z "$SECRET" ]] && { echo "ERROR: secret_name required for revoke"; exit 1; }
              scripts/automation/gcp-gsm-emergency-recovery.sh revoke "$SECRET"
              ;;
            compromise)
              [[ -z "$SECRET" ]] && { echo "ERROR: secret_name required for compromise"; exit 1; }
              scripts/automation/gcp-gsm-emergency-recovery.sh compromise "$SECRET" "$REASON"
              ;;
            exposure)
              [[ -z "$SECRET" ]] && { echo "ERROR: secret_name required for exposure"; exit 1; }
              scripts/automation/gcp-gsm-emergency-recovery.sh exposure "$SECRET" "$REASON"
              ;;
            mass-rotate)
              scripts/automation/gcp-gsm-emergency-recovery.sh mass-rotate
              ;;
            verify)
              [[ -z "$SECRET" ]] && { echo "ERROR: secret_name required for verify"; exit 1; }
              scripts/automation/gcp-gsm-emergency-recovery.sh verify "$SECRET"
              ;;
            audit)
              scripts/automation/gcp-gsm-emergency-recovery.sh audit
              ;;
            *)
              echo "ERROR: Unknown action: $ACTION"
              exit 1
              ;;
          esac

      - name: Generate incident report
        if: always()
        run: |
          REPORT_FILE=".github/workflows/logs/incident-report-$(date +%s).md"

          {
            echo "# GSM Emergency Incident Report"
            echo ""
            echo "| Field | Value |"
            echo "|-------|-------|"
            echo "| Incident ID | ${{ steps.response.outputs.incident_id }} |"
            echo "| Action | ${{ steps.response.outputs.action }} |"
            echo "| Timestamp | $(date -u +%Y-%m-%dT%H:%M:%SZ) |"
            echo "| Status | ✅ COMPLETED |"
            echo ""

            if [[ -f ".github/workflows/logs/gcp-gsm-emergency-"* ]]; then
              echo "## Response Log"
              echo "\`\`\`"
              tail -40 .github/workflows/logs/gcp-gsm-emergency-*
              echo "\`\`\`"
            fi
          } | tee "$REPORT_FILE"
        continue-on-error: true

      - name: Post incident summary to issue
        if: always()
        uses: actions/github-script@v7
        with:
          script: |
            const incident_id = "${{ steps.response.outputs.incident_id }}";
            const action = "${{ steps.response.outputs.action }}";

            const comment = `## 🚨 Emergency Response Completed

**Incident ID**: \`${incident_id}\`
**Action**: ${action}
**Timestamp**: ${new Date().toISOString()}
**Status**: ✅ Completed

### Action Details
- Automated emergency response executed
- All GSM credentials in affected scope processed
- Audit trail created for compliance
- Incident report generated

### Next Steps
1. Review incident report in workflow logs
2. Investigate root cause of breach
3. Generate replacement credentials
4. Update GitHub secrets with new values
5. Monitor for unauthorized access attempts

**Questions?** Reply to this issue or check the incident report.`;

            try {
              await github.rest.issues.createComment({
                owner: context.repo.owner,
                repo: context.repo.repo,
                issue_number: context.issue.number,
                body: comment
              });
            } catch(e) {
              console.log('Could not comment on issue:', e.message);
            }
        continue-on-error: true

      - name: Create high-priority ops issue
        if: steps.response.outputs.action != 'audit'
        uses: actions/github-script@v7
        with:
          script: |
            const incident_id = "${{ steps.response.outputs.incident_id }}";
            const action = "${{ steps.response.outputs.action }}";

            try {
              const { data: issue } = await github.rest.issues.create({
                owner: context.repo.owner,
                repo: context.repo.repo,
                title: `🔴 [INCIDENT] GSM Emergency Response - ${incident_id}`,
                body: `## Emergency Incident Details

**Incident ID**: \`${incident_id}\`
**Response Type**: ${action}
**Timestamp**: ${new Date().toISOString()}

### Action Taken
- GSM credentials revoked immediately
- All versions destroyed
- Audit trail created
- Notifications sent

### Operator Action Required
1. ✅ Emergency response complete (system automated)
2. ⏳ **Investigate** root cause
3. ⏳ **Generate** replacement credentials
4. ⏳ **Update** GitHub secrets with new values
5. ⏳ **Monitor** for unauthorized access

### References
- Parent Issue: #${{ github.event.issue.number }}
- Incident Report: Check workflow logs for full details`,
                labels: ['emergency', 'ops', 'gcp-gsm', 'incident-response'],
                assignees: []
              });

              console.log(\`Created incident tracking issue #\${issue.number}\`);
            } catch(e) {
              console.log('Could not create incident issue:', e.message);
            }
        continue-on-error: true

      - name: Escalate to ops team (Slack)
        if: always()
        uses: actions/github-script@v7
        with:
          script: |
            const incident_id = "${{ steps.response.outputs.incident_id }}";
            const action = "${{ steps.response.outputs.action }}";

            // Slack webhook URL stored in environment (via GitHub secret)
            // Would need SLACK_EMERGENCY_WEBHOOK secret configured
            console.log(`🚨 Emergency Response Escalation`);
            console.log(`  Incident: ${incident_id}`);
            console.log(`  Action: ${action}`);
            console.log(`  Status: Awaiting operator validation`);
        continue-on-error: true

      - name: Cleanup emergency logs (keep last 20)
        run: |
          ls -t .github/workflows/logs/gcp-gsm-emergency-* 2>/dev/null | tail -n +21 | xargs rm -f 2>/dev/null || true
        continue-on-error: true
