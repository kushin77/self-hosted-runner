name: Self-hosted Runner E2E (simulate)
permissions:
  contents: read
  id-token: write
  actions: read

on:
  workflow_dispatch:
    inputs:
      simulate:
        description: 'Run in simulate mode to validate flow without Vault'
        required: false
        default: 'true'
  workflow_run:
    workflows: ["Preflight Checks"]
    types: [completed]

jobs:
  simulate-e2e:
    name: Simulate E2E on self-hosted runner
    if: ${{ github.event_name != 'workflow_run' || github.event.workflow_run.conclusion == 'success' }}
    concurrency:
      group: self-hosted-e2e-simulate-${{ github.ref || github.run_id }}
      cancel-in-progress: false
    runs-on: self-hosted
    steps:
            - name: Load resilience helpers
              run: |
                set -euo pipefail
                source .github/scripts/resilience.sh || true
      - name: Checkout
        uses: actions/checkout@v4

      - name: Ensure scripts are executable
        run: |
          chmod +x scripts/ci/run-e2e-self-hosted-with-vault.sh || true

      - name: Run E2E (simulate)
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          set -euo pipefail
          echo "Running simulate E2E (no Vault required)"
          ./scripts/ci/run-e2e-self-hosted-with-vault.sh -s