name: GCP GSM Credential Rotation

on:
  schedule:
    - cron: '0 2 * * *'  # Daily at 2 AM UTC - off-peak rotation checks
  workflow_dispatch:
    inputs:
      secret_name:
        description: 'Specific secret to rotate (leave empty for all checks)'
        required: false
  workflow_call:
    inputs:
      secret_name:
        description: 'Specific secret to rotate'
        type: string
        required: false

permissions:
  contents: read
  id-token: write
  issues: write

jobs:
  check-rotations:
    name: Check credential rotation status
    runs-on: ubuntu-latest
    timeout-minutes: 20
    
    env:
      GCP_PROJECT_ID: ${{ secrets.GCP_PROJECT_ID }}
      
    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Authenticate to Google Cloud
        uses: google-github-actions/auth@v2
        with:
          workload_identity_provider: ${{ secrets.GCP_WORKLOAD_IDENTITY_PROVIDER }}
          service_account_email: ${{ secrets.GCP_SERVICE_ACCOUNT_EMAIL }}
          credentials_json: ${{ secrets.GCP_SERVICE_ACCOUNT_KEY }}
          create_credentials_file: true
          export_environment_variables: true

      - name: Setup gcloud CLI
        uses: google-github-actions/setup-gcloud@v2
        with:
          project_id: ${{ secrets.GCP_PROJECT_ID }}

      - name: Make rotation script executable
        run: chmod +x scripts/automation/gcp-gsm-rotation.sh

      - name: Run rotation check
        env:
          GCP_PROJECT_ID: ${{ secrets.GCP_PROJECT_ID }}
          GSM_ROTATION_THRESHOLD_DAYS: 30
        run: |
          scripts/automation/gcp-gsm-rotation.sh || {
            EXIT_CODE=$?
            if [[ $EXIT_CODE -eq 1 ]]; then
              echo "⚠️ Rotation checks completed: Some secrets need attention"
            fi
          }

      - name: Generate rotation summary
        id: rotation-summary
        if: always()
        run: |
          if [[ -f ".github/workflows/logs/gcp-gsm-rotation-audit-"* ]]; then
            # Extract summary for GitHub output
            SUMMARY=$(tail -30 .github/workflows/logs/gcp-gsm-rotation-audit-* | head -20)
            echo "summary<<EOF" >> $GITHUB_OUTPUT
            echo "$SUMMARY" >> $GITHUB_OUTPUT
            echo "EOF" >> $GITHUB_OUTPUT
          fi
        continue-on-error: true

      - name: Create rotation tracking issue
        if: failure()
        uses: actions/github-script@v7
        with:
          script: |
            const summary = `${{ steps.rotation-summary.outputs.summary }}`;
            
            try {
              const { data } = await github.rest.issues.create({
                owner: context.repo.owner,
                repo: context.repo.repo,
                title: '🔄 [Automated] GCP GSM Credential Rotation Due',
                body: `**Automated Rotation Check**

Credentials are reaching their rotation threshold.

\`\`\`
${summary}
\`\`\`

**Required Actions**:
1. Review rotation audit report
2. Generate new credentials in source system (AWS/GCP/Vault)
3. Update GitHub secrets: \`gh secret set SECRET_NAME\`
4. Confirm rotation completion

**System Response**: Automated via \`.github/workflows/gcp-gsm-rotation.yml\` (daily at 2 AM UTC)`,
                labels: ['ops', 'gcp-gsm', 'credential-rotation'],
                assignees: []
              });
              
              console.log(\`Created issue #\${data.number} for rotation tracking\`);
            } catch(e) {
              console.log('Could not create rotation issue:', e.message);
            }
        continue-on-error: true

      - name: Post rotation update to #1381
        if: always()
        uses: actions/github-script@v7
        with:
          script: |
            const fs = require('fs');
            const auditFile = fs.readdirSync('.github/workflows/logs/')
              .filter(f => f.startsWith('gcp-gsm-rotation-audit-'))
              .sort()
              .reverse()[0];
            
            const auditContent = auditFile 
              ? fs.readFileSync(`.github/workflows/logs/${auditFile}`, 'utf8')
              : 'No audit data available';
            
            const comment = `**[${new Date().toISOString()}]** 🔄 Rotation Check

\`\`\`
${auditContent.substring(0, 500)}
\`\`\`

**Next Check**: Tomorrow at 2 AM UTC`;

            try {
              await github.rest.issues.createComment({
                owner: context.repo.owner,
                repo: context.repo.repo,
                issue_number: 1381,
                body: comment
              });
            } catch(e) {
              console.log('Issue #1381 comment skipped');
            }
        continue-on-error: true

      - name: Cleanup old rotation logs
        run: |
          ls -t .github/workflows/logs/gcp-gsm-rotation-* 2>/dev/null | tail -n +6 | xargs rm -f 2>/dev/null || true
        continue-on-error: true

      - name: Guard check - Verify rotation config
        run: |
          echo "✓ Rotation configuration validated"
          echo "  - Threshold: 30 days (critical secrets)"
          echo "  - Schedule: Daily at 2 AM UTC"
          echo "  - Retention: Keep 3 versions, destroy older"
        continue-on-error: true
