name: Dependabot Triage

on:
  schedule:
    - cron: '0 3 * * *' # run daily at 03:00 UTC
  workflow_dispatch:

permissions:
  issues: write
  contents: read

jobs:
  report:
    runs-on: ubuntu-latest
    steps:
      - name: Gather open dependabot alerts
        id: alerts
        run: |
          set -euo pipefail
          REPO="${{ github.repository }}"
          alerts=$(gh api "/repos/${REPO}/dependabot/alerts?state=open" --jq '.[] | "#\(.number) - \(.security_advisory.summary) (\(.security_advisory.severity))"' 2>/dev/null || echo "")
          count=$(echo "$alerts" | grep -c '^#' || echo 0)
          echo "alerts=$alerts" >> "$GITHUB_OUTPUT"
          echo "count=$count" >> "$GITHUB_OUTPUT"

      - name: Update dependabot issue
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          set -euo pipefail
          REPO="${{ github.repository }}"
          ISSUE=1349
          count=${{ steps.alerts.outputs.count }}
          body="### Dependabot Alert Summary\n\n- Open alerts: $count\n\n" \
               "$(echo "${{ steps.alerts.outputs.alerts }}")"

          # Ensure an issue exists to post updates to; create idempotently if absent
          if ! gh issue view ${ISSUE} --repo ${REPO} >/dev/null 2>&1; then
            CREATED=$(gh issue create --repo ${REPO} --title "Dependabot Alerts" --body "Auto-created dependabot triage issue. This will be updated daily by automation." --label "dependabot" --json number --jq .number 2>/dev/null || true)
            if [ -n "$CREATED" ]; then
              ISSUE=$CREATED
            fi
          fi

          # find existing comment
          existing=$(gh api "/repos/${REPO}/issues/${ISSUE}/comments" --jq ".[] | select(.body | contains(\"Dependabot Alert Summary\")) | .id" 2>/dev/null | head -1 || true)
          if [ -n "$existing" ]; then
            gh api "/repos/${REPO}/issues/comments/${existing}" -X PATCH -f body="$body" || true
            echo "Updated dependabot summary comment"
          else
            gh issue comment $ISSUE --repo $REPO --body "$body" || true
            echo "Posted new dependabot summary comment"
          fi

          # auto-close issue when no alerts remain and close any label-based dependabot issues
          if [ "$count" -eq 0 ]; then
            gh issue update $ISSUE --repo $REPO --state closed --state_reason completed || true
            # Close any other open issues labeled 'dependabot' or 'dependabot-triage'
            for i in $(gh issue list --repo ${REPO} --label "dependabot" --state open --json number --jq '.[].number' 2>/dev/null || true); do
              gh issue update ${i} --repo ${REPO} --state closed --state_reason completed || true
            done
            for i in $(gh issue list --repo ${REPO} --label "dependabot-triage" --state open --json number --jq '.[].number' 2>/dev/null || true); do
              gh issue update ${i} --repo ${REPO} --state closed --state_reason completed || true
            done
            echo "Closed dependabot issue(s) since no alerts remain"
          fi
