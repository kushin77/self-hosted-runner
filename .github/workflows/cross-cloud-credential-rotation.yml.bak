name: Cross-Cloud Credential Rotation Orchestration

on:
  schedule:
    - cron: '0 3 * * *'  # Daily at 3 AM UTC (after GCP sync, before other rotations)
  workflow_dispatch:
    inputs:
      mode:
        description: 'Rotation mode'
        type: choice
        options:
          - check
          - rotate
          - emergency
        default: 'check'

permissions:
  contents: read
  id-token: write
  issues: write
  secrets: write

jobs:
  orchestrate-rotations:
    name: Orchestrate Multi-Cloud Credential Rotations
    runs-on: ubuntu-latest
    timeout-minutes: 30
    
    outputs:
      rotation_status: ${{ steps.orchestrate.outputs.status }}
      failed_services: ${{ steps.orchestrate.outputs.failed }}
    
    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Authenticate to Google Cloud (OIDC)
        uses: google-github-actions/auth@v2
        with:
          workload_identity_provider: ${{ secrets.GCP_WORKLOAD_IDENTITY_PROVIDER }}
          service_account_email: ${{ secrets.GCP_SERVICE_ACCOUNT_EMAIL }}
          credentials_json: ${{ secrets.GCP_SERVICE_ACCOUNT_KEY }}
          create_credentials_file: true
          export_environment_variables: true

      - name: Setup gcloud CLI
        uses: google-github-actions/setup-gcloud@v2
        with:
          project_id: ${{ secrets.GCP_PROJECT_ID }}

      - name: Configure AWS credentials (OIDC)
        uses: aws-actions/configure-aws-credentials@v2
        with:
          role-to-assume: ${{ secrets.AWS_ROLE_TO_ASSUME }}
          role-session-name: github-credential-rotation
          aws-region: us-east-1

      - name: Make scripts executable
        run: |
          chmod +x scripts/automation/cross-cloud-credential-orchestrator.sh
          chmod +x scripts/automation/credential-orchestration-engine.sh

      - name: Execute credential rotation orchestration
        id: orchestrate
        env:
          GCP_PROJECT_ID: ${{ secrets.GCP_PROJECT_ID }}
          GCP_SERVICE_ACCOUNT_EMAIL: ${{ secrets.GCP_SERVICE_ACCOUNT_EMAIL }}
          AWS_ROLE_TO_ASSUME: ${{ secrets.AWS_ROLE_TO_ASSUME }}
          VAULT_ADDR: ${{ secrets.VAULT_ADDR }}
          VAULT_ROLE_ID: ${{ secrets.VAULT_ROLE_ID }}
          VAULT_SECRET_ID: ${{ secrets.VAULT_SECRET_ID }}
          ROTATION_MODE: ${{ inputs.mode || 'check' }}
          SLACK_WEBHOOK_ROTATION: ${{ secrets.SLACK_WEBHOOK_ROTATION }}
        run: |
          set -e
          MODE="${ROTATION_MODE:-check}"
          echo "status=in-progress" >> $GITHUB_OUTPUT
          
          # Execute orchestration
          if scripts/automation/credential-orchestration-engine.sh; then
            echo "status=success" >> $GITHUB_OUTPUT
            echo "failed=" >> $GITHUB_OUTPUT
          else
            echo "status=warning" >> $GITHUB_OUTPUT
            echo "failed=some-services" >> $GITHUB_OUTPUT
          fi

      - name: Generate rotation audit log
        if: always()
        run: |
          LOG_FILES=$(ls -t .github/workflows/logs/cross-cloud-rotation-* 2>/dev/null | head -1)
          if [ -f "$LOG_FILES" ]; then
            echo "### Rotation Audit Log"
            tail -50 "$LOG_FILES" | head -40
          fi

      - name: Post rotation summary to issue #1381
        if: always()
        uses: actions/github-script@v7
        with:
          script: |
            const status = "${{ steps.orchestrate.outputs.rotation_status }}";
            const timestamp = new Date().toISOString();
            
            const comment = `**[${timestamp}]** 🔄 Cross-Cloud Credential Rotation

Status: ${status === 'success' ? '✅ SUCCESS' : '⚠️ ' + status}

**Rotated Services**:
- AWS IAM Access Keys
- GCP Service Account Keys
- Vault Authentication Tokens

**Next Rotation**: Tomorrow at 3 AM UTC`;

            try {
              await github.rest.issues.createComment({
                owner: context.repo.owner,
                repo: context.repo.repo,
                issue_number: 1381,
                body: comment
              });
            } catch(e) {
              console.log('Could not post to #1381');
            }
        continue-on-error: true

      - name: Create rotation tracking issue if failed
        if: steps.orchestrate.outputs.status != 'success'
        uses: actions/github-script@v7
        with:
          script: |
            const failed = "${{ steps.orchestrate.outputs.failed_services }}";
            
            if (failed) {
              await github.rest.issues.create({
                owner: context.repo.owner,
                repo: context.repo.repo,
                title: '⚠️ [AUTO] Cross-cloud credential rotation - Manual attention needed',
                body: `**Failed Services**: ${failed}

Automated rotation encountered issues. Manual verification recommended.

**Actions**:
1. Review rotation logs in workflow artifacts
2. Verify each cloud provider's credential status
3. Manually rotate any failed credentials
4. Update GitHub secrets with new values

**Automation will retry tomorrow at 3 AM UTC**`,
                labels: ['ops', 'automated', 'credential-rotation', 'action-required']
              });
            }
        continue-on-error: true

      - name: Cleanup old rotation logs
        run: |
          ls -t .github/workflows/logs/cross-cloud-rotation-* 2>/dev/null | tail -n +6 | xargs rm -f 2>/dev/null || true
        continue-on-error: true

      - name: Guard: Verify credential accessibility
        run: |
          echo "✓ Verifying credential accessibility post-rotation"
          
          # AWS
          if aws sts get-caller-identity >/dev/null 2>&1; then
            echo "  ✓ AWS credentials accessible"
          else
            echo "  ✗ AWS credentials inaccessible"
          fi
          
          # GCP
          if gcloud auth list --filter=status:ACTIVE --format="value(account)" 2>/dev/null | grep -q .; then
            echo "  ✓ GCP credentials accessible"
          else
            echo "  ✗ GCP credentials inaccessible"
          fi
          
          # Vault
          if [ -n "$VAULT_ADDR" ]; then
            if vault version >/dev/null 2>&1; then
              echo "  ✓ Vault accessible"
            else
              echo "  ✗ Vault inaccessible"
            fi
          fi
        env:
          VAULT_ADDR: ${{ secrets.VAULT_ADDR }}
        continue-on-error: true
