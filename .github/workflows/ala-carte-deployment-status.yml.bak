name: 🍽️ Ala Carte Deployment Info — Real-Time Status Generation

on:
  workflow_dispatch:
  schedule:
    # Every 15 minutes during business hours
    - cron: '*/15 7-19 * * *'
    # Every hour off-hours for status updates
    - cron: '0 0-6,20-23 * * *'

jobs:
  generate-status:
    name: Generate Ala Carte Deployment Status
    runs-on: ubuntu-latest
    
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4
        with:
          ref: main
          token: ${{ secrets.GITHUB_TOKEN }}
      
      - name: Generate deployment status
        run: |
          chmod +x ./scripts/generate-ala-carte-deployment-info.sh
          bash ./scripts/generate-ala-carte-deployment-info.sh \
            kushin77 \
            self-hosted-runner \
            1702
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
      
      - name: Commit status artifacts (if needed)
        if: always()
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "41898282+github-actions[bot]@users.noreply.github.com"
          
          if git status --porcelain | grep -q "^?? DEPLOYMENT_STATUS_"; then
            git add DEPLOYMENT_STATUS_*.md
            git commit -m "docs: Auto-generated deployment status ($(date -u '+%Y-%m-%d %H:%M UTC'))" || true
            git push origin main || true
          fi
      
      - name: Summary
        if: always()
        run: |
          echo "## 🍽️ Ala Carte Status Generated" >> $GITHUB_STEP_SUMMARY
          echo "" >> $GITHUB_STEP_SUMMARY
          echo "✅ Deployment status analyzed" >> $GITHUB_STEP_SUMMARY
          echo "✅ GitHub issue #1702 updated" >> $GITHUB_STEP_SUMMARY
          echo "✅ Status report posted" >> $GITHUB_STEP_SUMMARY
