---
name: "Auto: Verify and DR tests after GCP secret ingestion"
permissions:
  contents: read
  id-token: write
  actions: read

on:
  issue_comment:
    types: [created, edited]

jobs:
  on-ingest-confirmation:
    name: Trigger verification and DR tests
    if: "${{ github.event.issue.number == 1239 && contains(github.event.comment.body, 'ingested: true') }}"
    runs-on: ubuntu-latest
    permissions:
      issues: write
      contents: read
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Load resilience helpers
        run: |
          set -euo pipefail
          source .github/scripts/resilience.sh || true

      - name: Post acknowledgment comment
        uses: actions/github-script@v7
        with:
          script: |
            github.rest.issues.createComment({
              issue_number: context.issue.number,
              owner: context.repo.owner,
              repo: context.repo.repo,
              body: '✅ Ingestion confirmed — triggering verification.'
            })

      - name: Dispatch verify-secrets-and-diagnose workflow
        run: |
          gh workflow run verify-secrets-and-diagnose.yml \
            --repo ${{ github.repository }} \
            --ref main || true
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}

      - name: Dispatch dr-smoke-test workflow
        run: |
          gh workflow run dr-smoke-test.yml \
            --repo ${{ github.repository }} \
            --ref main || true
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}

      - name: Post follow-up comment with run links (best-effort)
        uses: actions/github-script@v7
        if: always()
        with:
          script: |
            github.rest.issues.createComment({
              issue_number: context.issue.number,
              owner: context.repo.owner,
              repo: context.repo.repo,
              body: "📊 Verification dispatched. See Actions tab."
            })
