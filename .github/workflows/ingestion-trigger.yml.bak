name: Operator Ingestion Trigger

on:
  issue_comment:
    types: [created]

permissions:
  issues: write
  actions: write
  contents: read

jobs:
  trigger-on-ingest:
    name: Trigger DR workflows on ingestion
    runs-on: ubuntu-latest
    steps:
      - name: Check comment and dispatch workflows
        uses: actions/github-script@v7
        with:
          github-token: ${{ secrets.GITHUB_TOKEN }}
          script: |
            const comment = context.payload.comment && context.payload.comment.body ? context.payload.comment.body.trim() : '';
            const issueNumber = context.payload.issue && context.payload.issue.number ? context.payload.issue.number : null;

            if (comment !== 'ingested: true') {
              core.info('Comment does not match trigger string; exiting.');
              return;
            }

            // Only respond to the designated operator issue to avoid accidental triggers
            const OPERATOR_ISSUE = 1239;
            if (issueNumber !== OPERATOR_ISSUE) {
              core.info(`Comment on issue #${issueNumber} ignored; expecting #${OPERATOR_ISSUE}.`);
              return;
            }

            core.info('Ingestion confirmed — dispatching DR verification and smoke-test workflows.');

            // Dispatch DR smoke test workflow
            await github.actions.createWorkflowDispatch({
              owner: context.repo.owner,
              repo: context.repo.repo,
              workflow_id: 'dr-smoke-test.yml',
              ref: 'main',
              inputs: {}
            });

            // Dispatch a targeted disaster recovery test (non-dry run)
            await github.actions.createWorkflowDispatch({
              owner: context.repo.owner,
              repo: context.repo.repo,
              workflow_id: 'docker-hub-weekly-dr-testing.yml',
              ref: 'main',
              inputs: { dry_run: 'false', verbose: 'true' }
            });

            // Acknowledge in the issue
            await github.issues.createComment({
              owner: context.repo.owner,
              repo: context.repo.repo,
              issue_number: OPERATOR_ISSUE,
              body: '✅ Ingestion detected. Triggered `dr-smoke-test.yml` and `docker-hub-weekly-dr-testing.yml`. I will monitor runs and post results.'
            });

            core.info('Dispatch complete.');
