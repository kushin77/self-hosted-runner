name: Auto-Resolve Missing Secrets Issue

on:
  # Converted to event-driven: removed frequent polling
  workflow_dispatch:

  workflow_call: {}
  repository_dispatch:
    types: [secrets-resolved, secrets-check]

concurrency:
  group: auto-resolve-missing-secrets-${{ github.ref }}
  cancel-in-progress: false

permissions:
  issues: write
  contents: read
  actions: read

jobs:
  auto-resolve:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Load resilience helpers
        run: |
          set -euo pipefail
          source .github/scripts/resilience.sh || true

      - name: Check if critical secrets are now present (idempotent)
        env:
          RUNNER_MGMT_TOKEN: ${{ secrets.RUNNER_MGMT_TOKEN }}
          DEPLOY_SSH_KEY: ${{ secrets.DEPLOY_SSH_KEY }}
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          set -euo pipefail
          REPO="${{ github.repository }}"

          missing=()
          if [ -z "${RUNNER_MGMT_TOKEN:-}" ]; then
            missing+=("RUNNER_MGMT_TOKEN")
          fi
          if [ -z "${DEPLOY_SSH_KEY:-}" ]; then
            missing+=("DEPLOY_SSH_KEY")
          fi

          if [ ${#missing[@]} -eq 0 ]; then
            echo "✅ Critical secrets are present. Looking for missing-secrets issues to resolve..."

            # Find any open issues labeled 'automation,ops,runners' or 'missing-secrets'
            ISSUE_NUM=$(gh issue list --repo ${REPO} --label "missing-secrets" --state open --json number --jq '.[0].number' 2>/dev/null || true)

            if [ -n "$ISSUE_NUM" ]; then
              echo "Found issue #${ISSUE_NUM}. All required secrets are now present."

              # Idempotent comment: check if resolution comment already exists
              EXISTING=$(gh api "/repos/${REPO}/issues/${ISSUE_NUM}/comments" --jq ".[] | select(.body | contains(\"Automated Resolution\")) | .id" 2>/dev/null | head -1 || true)
              if [ -z "$EXISTING" ]; then
                gh issue comment ${ISSUE_NUM} --repo ${REPO} --body "✅ **Automated Resolution**

All required secrets are now present:
- ✅ RUNNER_MGMT_TOKEN
- ✅ DEPLOY_SSH_KEY

This issue is being automatically closed. The runner self-heal workflow will execute within the next 5 minutes to verify runners are operational.

If secrets need to be refreshed or issues persist, please comment on this issue or create a new one.

**Automation**: $(date -u +'%Y-%m-%dT%H:%M:%SZ')" || true
              fi

              # Close the issue idempotently
              gh issue update ${ISSUE_NUM} --repo ${REPO} --state closed --state_reason completed || true
              echo "✅ Closed issue #${ISSUE_NUM} - all required secrets are configured"
            else
              echo "No missing-secrets issue found - system is in healthy state"
            fi
          else
            echo "ℹ️  Still missing secrets: ${missing[*]}"
            echo "Will check again on next scheduled run (5 minutes)"
          fi
